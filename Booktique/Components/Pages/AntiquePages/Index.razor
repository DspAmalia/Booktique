@page "/antique"
@using Microsoft.EntityFrameworkCore
@using Booktique.Models.MainModels
@implements IAsyncDisposable
@inject IDbContextFactory<BooktiqueContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Antique Booktique | Booktique</PageTitle>

<div class="antique-shop-floor py-5">
    <div class="container">
        <div class="shop-sign text-center mb-5 p-4">
            <h1 class="antique-title">Antique Booktique</h1>
            <div class="separator"><i class="bi bi-feather"></i></div>
            <p class="antique-subtitle">Rare Finds & Pre-loved Treasures from Our Annual Members</p>

            <button class="btn btn-ink mt-3 rounded-0 px-4" @onclick='() => NavigationManager.NavigateTo("antique/create")'>
                <i class="bi bi-journal-plus me-2"></i>List a Treasure
            </button>
        </div>

        @* --- SECȚIUNE FILTRE (Vizibilă pentru Manageri sau extinsă pentru toți) --- *@
        @if (isManager)
        {
            <div class="archive-filter-box mb-5 p-3 d-flex align-items-center justify-content-between">
                <span class="font-serif italic text-gold"><i class="bi bi-filter-square me-2"></i>Archive Ledger Filter:</span>
                <div class="btn-group panel-pills">
                    <button class="btn btn-scroll-sm @(selectedFilter == "All" ? "active" : "")" @onclick='() => ChangeFilter("All")'>All Registry</button>
                    <button class="btn btn-scroll-sm @(selectedFilter == "Pending" ? "active" : "")" @onclick='() => ChangeFilter("Pending")'>⏳ Pending</button>
                    <button class="btn btn-scroll-sm @(selectedFilter == "Valid" ? "active" : "")" @onclick='() => ChangeFilter("Valid")'>✓ Validated</button>
                    <button class="btn btn-scroll-sm @(selectedFilter == "Invalid" ? "active" : "")" @onclick='() => ChangeFilter("Invalid")'>✗ Invalidated</button>
                </div>
            </div>
        }

        @if (books == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-sepia" role="status"></div>
                <p class="text-sepia mt-2 italic">Unrolling the scrolls...</p>
            </div>
        }
        else if (!books.Any())
        {
            <div class="empty-shelf text-center py-5">
                <i class="bi bi-archive display-1"></i>
                <p class="mt-3">The shelves are dusty and empty. No records match this criterion.</p>
            </div>
        }
        else
        {
            <div class="row g-5">
                @foreach (var item in books)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="book-tome @(item.BookStock <= 0 ? "sold-tome" : "")">
                            <div class="tome-frame">
                                <img src="@(string.IsNullOrEmpty(item.BookCoverPath) ? "/images/default-book.png" : item.BookCoverPath)"
                                     class="tome-img" alt="@item.BookTitle">

                                <div class="tome-price">
                                    @item.BookPrice RON
                                </div>

                                @* Badge-uri de Status vizibile doar pentru Manager *@
                                @if (isManager)
                                {
                                    <div class="manager-status-badge">
                                        @if (item.IsApproved == true)
                                        {
                                            <span class="badge bg-success text-white">VALID</span>
                                        }
                                        else if (item.IsApproved == false)
                                        {
                                            <span class="badge bg-danger text-white">INVALID</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">PENDING</span>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="tome-details mt-3 position-relative">
                                @if (item.BookStock <= 0)
                                {
                                    <div class="wax-seal">SOLD</div>
                                }

                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="tome-condition">@item.BookCategory</span>
                                    <span class="tome-date pe-4">Edition: @item.BookYear</span>
                                </div>

                                <h4 class="tome-title">@item.BookTitle</h4>
                                <p class="tome-author">by @item.BookAuthor</p>

                                <div class="tome-description">
                                    <p>@item.BookDescription</p>
                                </div>

                                <div class="tome-actions d-flex flex-column gap-2 mt-3">
                                    <div class="d-flex gap-2">
                                        <button class="btn-scroll w-100" @onclick='() => NavigationManager.NavigateTo($"antique/details?id={item.BookId}")'>
                                            View Chronicle
                                        </button>

                                        @if (item.BookStock > 0 && currentUserId != item.SellerId.ToString())
                                        {
                                            <a href="/chat?targetUserId=@item.SellerId&initialMessage=Greetings, @(item.Seller?.UserName ?? "Curator")! I am interested in the volume: @item.BookTitle"
                                               class="btn-ink-sm"
                                               title="Contact Curator">
                                                <i class="bi bi-chat-left-quote"></i>
                                            </a>
                                        }
                                    </div>

                                    @* --- COMANDE MODERARE MANAGER --- *@
                                    @if (isManager)
                                    {
                                        <div class="manager-decision-zone d-flex gap-2 pt-2 border-top border-dark border-opacity-10">
                                            <button class="btn btn-outline-success btn-sm w-50 d-flex align-items-center justify-content-center gap-1" 
                                                    disabled="@(item.IsApproved == true)"
                                                    @onclick="() => SetApprovalStatus(item.BookId, true)">
                                                <i class="bi bi-check-circle-fill"></i> Valid
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm w-50 d-flex align-items-center justify-content-center gap-1" 
                                                    disabled="@(item.IsApproved == false)"
                                                    @onclick="() => SetApprovalStatus(item.BookId, false)">
                                                <i class="bi bi-x-circle-fill"></i> Invalid
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=IM+Fell+English+SC&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

    :root {
        --dark-wood: #3d2b1f;
        --ink-color: #2c1e14;
        --sepia-paper: #f4ecd8;
        --wax-red: #8b0000;
        --wax-dark: #5e0000;
        --accent-gold: #c5a059;
    }

    body {
        background-image: url('https://www.transparenttextures.com/patterns/dark-wood.png'), linear-gradient(to bottom, #2c1e14, #3d2b1f);
    }

    .antique-shop-floor {
        min-height: 100vh;
        color: var(--sepia-paper);
        font-family: 'Playfair Display', serif;
    }

    .shop-sign {
        background-color: var(--sepia-paper);
        border: 8px double var(--dark-wood);
        color: var(--ink-color);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border-radius: 2px;
    }

    .separator {
        color: var(--accent-gold);
        font-size: 1.5rem;
        margin: 10px 0;
    }

    .antique-subtitle {
        font-style: italic;
        font-size: 1.2rem;
    }

    .antique-title {
        font-family: 'IM Fell English SC', serif;
        font-size: 3.5rem;
        margin-bottom: 0;
    }

    .book-tome {
        background: var(--sepia-paper);
        padding: 20px;
        color: var(--ink-color);
        border-radius: 2px;
        box-shadow: 5px 5px 15px rgba(0,0,0,0.3);
        position: relative;
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.1);
    }

        .book-tome:hover {
            transform: rotate(-1deg) scale(1.02);
            box-shadow: 15px 15px 30px rgba(0,0,0,0.4);
        }

    .wax-seal {
        position: absolute;
        top: 50px;
        right: -10px;
        width: 75px;
        height: 75px;
        background: var(--wax-red);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Cinzel', serif;
        font-weight: bold;
        font-size: 0.9rem;
        z-index: 10;
        border-radius: 46% 54% 51% 49% / 55% 44% 56% 45%;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.4), inset 2px 2px 4px rgba(255,255,255,0.2), inset -2px -2px 4px rgba(0,0,0,0.4);
        border: 2px solid var(--wax-dark);
        transform: rotate(15deg);
        text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    }

        .wax-seal::after {
            content: '';
            position: absolute;
            width: 80%;
            height: 80%;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50%;
        }

    .tome-frame {
        position: relative;
        border: 5px solid white;
        height: 300px;
        overflow: hidden;
    }

    .tome-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: sepia(0.3) contrast(1.1);
    }

    .tome-price {
        position: absolute;
        bottom: 0;
        right: 0;
        background: var(--dark-wood);
        color: var(--accent-gold);
        padding: 5px 15px;
        font-family: 'Cinzel', serif;
    }

    .tome-title {
        font-family: 'Cinzel', serif;
        font-weight: 700;
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }

    .tome-condition {
        font-size: 0.7rem;
        text-transform: uppercase;
        background: var(--accent-gold);
        color: white;
        padding: 2px 8px;
    }

    .btn-scroll {
        background: transparent;
        border: 1px solid var(--ink-color);
        font-family: 'Cinzel', serif;
    }

        .btn-scroll:hover {
            background: var(--ink-color);
            color: var(--sepia-paper);
        }

    .btn-ink {
        background: var(--ink-color);
        color: var(--accent-gold);
        font-family: 'Cinzel', serif;
    }

        .btn-ink:hover {
            background: var(--accent-gold);
        }

    .btn-ink-sm {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        text-decoration: none;
        background: var(--dark-wood);
        color: var(--accent-gold);
        border: 2px solid var(--accent-gold);
        border-radius: 4px;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.4);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

        .btn-ink-sm:hover {
            background: var(--accent-gold);
            color: var(--ink-color);
            box-shadow: 0 0 12px rgba(197, 160, 89, 0.6);
            transform: translateY(-2px);
        }

    .archive-filter-box {
        background: rgba(44, 30, 20, 0.6);
        border: 1px solid var(--accent-gold);
        border-radius: 4px;
    }

    .btn-scroll-sm {
        background: transparent;
        border: 1px solid var(--accent-gold);
        color: var(--sepia-paper);
        font-family: 'Cinzel', serif;
        font-size: 0.85rem;
        padding: 6px 16px;
        transition: 0.2s;
    }

    .btn-scroll-sm:hover, .btn-scroll-sm.active {
        background: var(--accent-gold);
        color: var(--ink-color) !important;
    }

    .manager-status-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        z-index: 5;
    }

    .manager-status-badge .badge {
        font-family: 'Cinzel', serif;
        letter-spacing: 1px;
        font-size: 0.75rem;
        box-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }
</style>

@code {
    private BooktiqueContext context = default!;
    private List<Book>? books;
    private string? currentUserId;
    
    // State management pentru filtre & drepturi
    private bool isManager = false;
    private string selectedFilter = "Pending"; // Managerii pornesc implicit din Pending ca să vadă ce au de lucru

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        ?? user.FindFirst("UserId")?.Value;

        // Verificăm dacă userul este Manager administrativ
        isManager = user.IsInRole("Manager") || user.IsInRole("Admin");

        // Dacă nu este manager, utilizatorul simplu vede automat DOAR cărțile deja validate
        if (!isManager)
        {
            selectedFilter = "Valid";
        }

        context = DbFactory.CreateDbContext();
        await LoadFilteredBooksAsync();
    }

    private async Task LoadFilteredBooksAsync()
    {
        var query = context.Book
            .Include(b => b.Seller)
            .Where(b => b.SellerId != null && b.SellerId != 0);

        if (selectedFilter == "Valid")
        {
            query = query.Where(b => b.IsApproved == true);
        }
        else if (selectedFilter == "Invalid")
        {
            query = query.Where(b => b.IsApproved == false);
        }
        else if (selectedFilter == "Pending")
        {
            query = query.Where(b => b.IsApproved == null);
        }

        books = await query.OrderByDescending(b => b.BookId).ToListAsync();
    }

    private async Task ChangeFilter(string newFilter)
    {
        selectedFilter = newFilter;
        await LoadFilteredBooksAsync();
    }

    private async Task SetApprovalStatus(int bookId, bool approved)
    {
        var targetBook = await context.Book.FirstOrDefaultAsync(b => b.BookId == bookId);
        if (targetBook != null)
        {
            targetBook.IsApproved = approved;
            await context.SaveChangesAsync();
            
            // Reîncărcăm lista pentru a muta instant cartea din listă dacă filtrul o cere
            await LoadFilteredBooksAsync();
        }
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}