@page "/chat"
@using Microsoft.AspNetCore.SignalR.Client
@using Booktique.Models.MainModels
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using static Booktique.Models.MainModels.User
@implements IAsyncDisposable
@inject IDbContextFactory<BooktiqueContext> DbFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Booktique Messenger</PageTitle>

<div class="main-wrapper py-2 py-md-4">
    <div class="container px-1 px-md-3">
        <div class="glass-card chat-main-container shadow-lg border-0">
            <div class="row g-0 h-100">

                @* Sidebar - Ascuns pe mobil dacă un utilizator este selectat *@
                <div class="col-md-4 border-end chat-sidebar @(selectedUserId != null ? "d-none d-md-block" : "d-block")">
                    <div class="p-3 border-bottom bg-brown text-white rounded-top-start d-flex align-items-center justify-content-between">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Readers</h5>
                    </div>
                    <div class="user-list p-2">
                        @if (users != null && users.Any())
                        {
                            @foreach (var user in users)
                            {
                                var unreadCount = unreadMessagesCounts.ContainsKey(user.UserId) ? unreadMessagesCounts[user.UserId] : 0;

                                <div class="user-item @(selectedUserId == user.UserId ? "active" : "") d-flex align-items-center justify-content-between"
                                     @onclick="() => UpdateSelectedUser(user.UserId)">
                                    
                                    <div class="d-flex align-items-center flex-grow-1 min-w-0">
                                        <div class="user-avatar position-relative flex-shrink-0">
                                            @if (!string.IsNullOrEmpty(user.ProfilePicture))
                                            {
                                                <img src="@user.ProfilePicture" alt="@user.UserName" class="rounded-circle shadow-sm" style="width: 100%; height: 100%; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                @user.UserName.Substring(0, 1).ToUpper()
                                            }
                                            
                                            @if (unreadCount > 0)
                                            {
                                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle animate-pulse"></span>
                                            }
                                        </div>
                                        <div class="user-details ms-2 flex-grow-1 text-truncate">
                                            <div class="fw-bold @(unreadCount > 0 ? "text-dark fw-extrabold" : "text-secondary")">@user.UserName</div>
                                            <div class="small text-truncate @(unreadCount > 0 ? "text-orange font-weight-bold" : "text-muted")">
                                                @(unreadCount > 0 ? $"{unreadCount} new messages" : "Click to start chatting")
                                            </div>
                                        </div>
                                    </div>

                                    @if (unreadCount > 0)
                                    {
                                        <span class="badge rounded-pill bg-brown px-2 py-1 shadow-sm small-badge ms-2">
                                            @unreadCount
                                        </span>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center p-4 text-muted small">No other subscribers online.</div>
                        }
                    </div>
                </div>

                @* Fereastra de Chat - Ocupă tot ecranul pe mobil dacă un utilizator este selectat *@
                <div class="col-md-8 d-flex flex-column chat-content @(selectedUserId == null ? "d-none d-md-flex" : "d-flex")">
                    @if (selectedUserId == null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted p-5 bg-light">
                            <i class="bi bi-chat-heart display-1 text-orange mb-3 opacity-25"></i>
                            <h4>Your Booktique Conversations</h4>
                            <p>Select a fellow reader from the list to start a chat.</p>
                        </div>
                    }
                    else
                    {
                        <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-white shadow-sm">
                            <div class="d-flex align-items-center min-w-0">
                                @* Buton de înapoi - Vizibil doar pe mobil *@
                                <button class="btn btn-sm btn-light border-0 me-2 d-md-none text-brown" type="button" @onclick="BackToUserList">
                                    <i class="bi bi-arrow-left fs-5"></i>
                                </button>
                                
                                <div class="user-avatar me-2 bg-orange text-white flex-shrink-0">
                                    @{
                                        var selectedUser = users.FirstOrDefault(u => u.UserId == selectedUserId);
                                        if (selectedUser != null && !string.IsNullOrEmpty(selectedUser.ProfilePicture))
                                        {
                                            <img src="@selectedUser.ProfilePicture" class="rounded-circle" style="width: 100%; height: 100%; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            @(selectedUser?.UserName?.Substring(0, 1).ToUpper())
                                        }
                                    }
                                </div>
                                <h6 class="mb-0 fw-bold text-brown text-truncate">
                                    @users.FirstOrDefault(u => u.UserId == selectedUserId)?.UserName
                                </h6>
                            </div>
                            <span class="badge @(hubConnection?.State == HubConnectionState.Connected ? "bg-success" : "bg-danger") rounded-pill flex-shrink-0 ms-2">
                                @(hubConnection?.State == HubConnectionState.Connected ? "Online" : "Offline")
                            </span>
                        </div>

                        <div class="chat-window p-3 p-md-4" id="chatWindow">
                            @{
                                DateTime? lastDate = null;
                            }
                            @foreach (var msg in chatMessages)
                            {
                                var localTime = msg.Timestamp.ToLocalTime();
                                
                                @if (lastDate == null || lastDate.Value.Date != localTime.Date)
                                {
                                    lastDate = localTime;
                                    <div class="chat-date-separator text-center my-3">
                                        <span class="badge bg-light text-muted border px-3 py-2 rounded-pill small shadow-sm">
                                            <i class="bi bi-calendar3 me-1"></i> @localTime.ToString("dd MMMM yyyy")
                                        </span>
                                    </div>
                                }

                                <div @key="msg.Timestamp.Ticks + msg.Text" class="message-container @(msg.IsOwnMessage ? "message-right" : "message-left")">
                                    <div class="message-bubble @(msg.IsOwnMessage ? "bubble-mine shadow-sm" : "bubble-other shadow-sm")">
                                        @if (!msg.IsOwnMessage)
                                        {
                                            <span class="message-user">@msg.User</span>
                                        }
                                        
                                        @if (msg.Text != null && msg.Text.StartsWith("[BOOK_CLUB]"))
                                        {
                                            var parts = msg.Text.Replace("[BOOK_CLUB]", "").Split('|');
                                            var bookTitle = parts.Length > 0 ? parts[0] : "Book";
                                            var bookAuthor = parts.Length > 1 ? parts[1] : "";
                                            var bookComment = parts.Length > 2 ? parts[2] : "";
                                            
                                            <div class="book-share-card p-2 my-1 bg-white text-dark rounded border border-warning shadow-xs">
                                                <div class="fw-bold text-brown small">
                                                    <i class="bi bi-book-half text-orange me-1"></i> Book Club
                                                </div>
                                                <div class="my-1 fw-bold text-dark text-truncate" style="font-size: 0.85rem;" title="@bookTitle">
                                                    @bookTitle
                                                </div>
                                                <div class="text-muted small mb-2" style="font-style: italic; font-size: 0.75rem;">
                                                    by @bookAuthor
                                                </div>
                                                <div class="p-2 bg-light rounded text-secondary small border-start border-3 border-warning" style="font-style: italic; font-size: 0.8rem;">
                                                    "@bookComment"
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="message-text">@msg.Text</div>
                                        }
                                        
                                        <div class="message-time d-flex align-items-center justify-content-end opacity-75 mt-1" style="font-size: 0.65rem;">
                                            <span>@localTime.ToString("HH:mm")</span>
                                            @if (msg.IsOwnMessage)
                                            {
                                                <i class="bi @(msg.IsRead ? "bi-check2-all text-info" : "bi-check2") ms-1" style="font-size: 0.8rem;"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="p-2 p-md-3 border-top bg-white chat-input-bar">
                            <div class="input-group">
                                <button class="btn btn-outline-brown rounded-pill-start px-2 px-md-3" type="button" @onclick="OpenBookModal" title="Recommend a book">
                                    <i class="bi bi-book text-orange" style="font-size: 1.1rem;"></i>
                                </button>
                                
                                <input @bind="messageInput"
                                       @bind:event="oninput"
                                       @onkeyup="HandleKeyUp"
                                       class="form-control border-2 border-end-0 border-light px-2 px-md-3 message-input-field"
                                       placeholder="Type a message..." />
                                <button class="btn btn-orange rounded-pill-end px-3 px-md-4"
                                        @onclick="Send"
                                        disabled="@IsButtonDisabled">
                                    <i class="bi bi-send-fill"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (isBookModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-sm-custom">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
                <div class="modal-header bg-brown text-white" style="border-top-left-radius: 1rem; border-top-right-radius: 1rem;">
                    <h5 class="modal-title fw-bold fs-6"><i class="bi bi-journal-bookmark-fill text-orange me-2"></i>Book Club</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseBookModal"></button>
                </div>
                <div class="modal-body p-3 p-md-4" style="background-color: #fdf6ee;">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-brown small">Choose the book from the shop</label>
                        <select class="form-select border-2 border-light form-select-sm" @bind="selectedBookId">
                            <option value="0">-- Select a Book --</option>
                            @foreach (var book in availableBooks)
                            {
                                <option value="@book.Id">@book.Title (by @book.Author)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-brown small">Your comm / Thoughts about the book</label>
                        <textarea class="form-control border-2 border-light small" rows="3" 
                                  placeholder="What did you like about this book?" 
                                  @bind="bookCommentInput"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2" style="border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;">
                    <button type="button" class="btn btn-sm btn-secondary rounded-pill px-3" @onclick="CloseBookModal">Close</button>
                    <button type="button" class="btn btn-sm btn-orange rounded-pill px-3" 
                            disabled="@(selectedBookId == 0 || string.IsNullOrWhiteSpace(bookCommentInput))" 
                            @onclick="SendBookRecommendation">
                        <i class="bi bi-share-fill me-1"></i> Share
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    :root {
        --brown-primary: #5a3e2b;
        --orange-accent: #f0a500;
        --chat-bg: #fdf6ee;
    }

    body {
        background-image: linear-gradient(rgba(253, 246, 238, 0.88), rgba(253, 246, 238, 0.88)), url('https://i.pinimg.com/1200x/33/99/ac/3399ac1d819b89bdb962b893c9554a41.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
    }

    .chat-main-container {
        height: 82vh; /* Mărit ușor înălțimea pentru a folosi mai bine ecranul mobil */
        min-height: 480px;
        background: white;
        border-radius: 1rem;
        overflow: hidden;
    }

    @@media (max-width: 767.98px) {
        .chat-main-container {
            height: calc(100vh - 70px); /* Ajustare dinamică pe mobil în funcție de ecran */
            border-radius: 0.5rem;
        }
    }

    .bg-brown {
        background-color: var(--brown-primary) !important;
    }

    .btn-outline-brown {
        color: var(--brown-primary);
        border: 2px solid #f1e6d8;
        border-right: none;
        background: #fdf6ee;
    }
    .btn-outline-brown:hover {
        background: #f1e6d8;
    }

    .btn-orange {
        background-color: var(--orange-accent);
        color: white;
        border: none;
    }

    .btn-orange:hover {
        background-color: #d49200;
        color: white;
    }

    .text-orange {
        color: var(--orange-accent);
    }

    .text-brown {
        color: var(--brown-primary);
    }

    .user-list {
        height: calc(100% - 58px);
        overflow-y: auto;
    }

    .user-item {
        padding: 10px 12px;
        margin-bottom: 5px;
        border-radius: 12px;
        cursor: pointer;
        transition: 0.2s;
    }

    .user-item:hover {
        background-color: #f8f1e9;
    }

    .user-item.active {
        background-color: #f1e6d8;
    }

    .fw-extrabold {
        font-weight: 800 !important;
    }

    .small-badge {
        font-size: 0.68rem;
        padding: 4px 6px !important;
    }

    .animate-pulse {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 5px rgba(220, 53, 69, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
    }

    .user-avatar {
        width: 38px;
        height: 38px;
        background: #ceb9a6;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .chat-sidebar, .chat-content {
        height: 100%;
    }

    .chat-window {
        flex: 1;
        overflow-y: auto;
        background-color: var(--chat-bg);
        display: flex;
        flex-direction: column;
    }

    .message-container {
        display: flex;
        margin-bottom: 10px;
        width: 100%;
    }

    .message-left {
        justify-content: flex-start;
    }

    .message-right {
        justify-content: flex-end;
    }

    .message-bubble {
        max-width: 85%; /* Mărit lățimea bulei pe mobil de la 75% la 85% */
        padding: 8px 14px;
        border-radius: 1rem;
        font-size: 0.9rem;
        word-break: break-word;
    }

    .bubble-mine {
        background-color: var(--brown-primary);
        color: white;
        border-bottom-right-radius: 0.2rem;
    }

    .bubble-other {
        background-color: white;
        color: #444;
        border-bottom-left-radius: 0.2rem;
        border: 1px solid #eee;
    }

    .message-user {
        font-size: 0.65rem;
        font-weight: bold;
        color: var(--orange-accent);
        display: block;
        margin-bottom: 2px;
    }

    .rounded-pill-start {
        border-top-left-radius: 50px;
        border-bottom-left-radius: 50px;
    }

    .rounded-pill-end {
        border-top-right-radius: 50px;
        border-bottom-right-radius: 50px;
    }

    .message-input-field {
        font-size: 0.95rem;
    }

    @@media (max-width: 576px) {
        .modal-sm-custom {
            margin: 0.5rem;
        }
    }

    ::-webkit-scrollbar {
        width: 4px;
    }

    ::-webkit-scrollbar-thumb {
        background: #ceb9a6;
        border-radius: 10px;
    }
</style>

@code {
    private HubConnection? hubConnection;
    private List<User> users = new();
    private readonly object _messageLock = new();
    private List<LocalMessage> chatMessages = new(); 
    private int? selectedUserId; 
    private string? messageInput;
    private int? currentUserId; 
    private string? currentUserName;

    private Dictionary<int, int> unreadMessagesCounts = new();

    private bool isBookModalOpen = false;
    private List<BookDummy> availableBooks = new(); 
    private int selectedBookId = 0;
    private string bookCommentInput = string.Empty;

    [SupplyParameterFromQuery]
    public string? targetUserId { get; set; }

    [SupplyParameterFromQuery]
    public string? initialMessage { get; set; }

    private bool hasAutoSent = false; 

    private bool IsButtonDisabled =>
        hubConnection?.State != HubConnectionState.Connected ||
        string.IsNullOrWhiteSpace(messageInput) ||
        selectedUserId == null;

    // Metodă nouă pentru revenirea la listă pe telefon
    private void BackToUserList()
    {
        selectedUserId = null;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                        ?? authState.User.FindFirst("UserId")?.Value;

        if (int.TryParse(userIdStr, out int parsedCurrentId))
        {
            currentUserId = parsedCurrentId;
        }

        currentUserName = authState.User.Identity?.Name ?? "Anonim";

        using var context = DbFactory.CreateDbContext();
        users = await context.User
            .Where(u => u.IsSubscribed != SubscriptionLevel.None && u.UserId != currentUserId)
            .ToListAsync();

        if (currentUserId.HasValue)
        {
            var unreadGroups = await context.ChatMessage
                .Where(m => m.ReceiverId == currentUserId.Value && !m.IsRead)
                .GroupBy(m => m.SenderId)
                .Select(g => new { SenderId = g.Key, Count = g.Count() })
                .ToListAsync();

            unreadMessagesCounts = new Dictionary<int, int>();

            foreach (var group in unreadGroups)
            {
                if (group.SenderId.HasValue)
                {
                    unreadMessagesCounts[group.SenderId.Value] = group.Count;
                }
            }
        }

        try 
        {
            availableBooks = await context.Book
                .Select(b => new BookDummy { Id = b.BookId, Title = b.BookTitle, Author = b.BookAuthor })
                .ToListAsync();
        }
        catch {
            availableBooks = new List<BookDummy> {
                new() { Id = 1, Title = "Mândrie și Prejudecată", Author = "Jane Austen" },
                new() { Id = 2, Title = "1984", Author = "George Orwell" }
            };
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, string, string>("ReceiveMessage", async (senderId, userName, text) =>
        {
            if (int.TryParse(senderId, out int parsedSenderId))
            {
                if (parsedSenderId == currentUserId) return;

                if (parsedSenderId == selectedUserId)
                {
                    var now = DateTime.UtcNow;

                    using (var dbContext = DbFactory.CreateDbContext())
                    {
                        var liveMsg = new ChatMessage
                            {
                                SenderId = parsedSenderId,
                                ReceiverId = currentUserId!.Value,
                                Text = text,
                                Timestamp = now,
                                IsRead = true
                            };
                        dbContext.ChatMessage.Add(liveMsg);
                        await dbContext.SaveChangesAsync();
                    }

                    lock (_messageLock)
                    {
                        chatMessages.Add(new LocalMessage
                            {
                                User = userName,
                                Text = text,
                                IsOwnMessage = false,
                                Timestamp = now,
                                IsRead = true
                            });
                    }
                    await InvokeAsync(StateHasChanged);
                    await ScrollToBottom();
                }
                else
                {
                    if (unreadMessagesCounts.ContainsKey(parsedSenderId))
                        unreadMessagesCounts[parsedSenderId]++;
                    else
                        unreadMessagesCounts[parsedSenderId] = 1;

                    await InvokeAsync(StateHasChanged);
                }
            }
        });

        await hubConnection.StartAsync();

        if (currentUserId.HasValue)
        {
            await hubConnection.InvokeAsync("RegisterUser", currentUserId.Value.ToString());
        }
    }

    private async Task UpdateSelectedUser(int userId)
    {
        selectedUserId = userId;
        
        using var context = DbFactory.CreateDbContext();
        
        var unreadDbMessages = await context.ChatMessage
            .Where(m => m.SenderId == selectedUserId && m.ReceiverId == currentUserId && !m.IsRead)
            .ToListAsync();

        if (unreadDbMessages.Any())
        {
            foreach (var msg in unreadDbMessages)
            {
                msg.IsRead = true;
            }
            await context.SaveChangesAsync();
        }

        if (unreadMessagesCounts.ContainsKey(userId))
        {
            unreadMessagesCounts[userId] = 0;
        }
        
        var dbMessages = await context.ChatMessage
            .Include(m => m.Sender)
            .Where(m => (m.SenderId == currentUserId && m.ReceiverId == selectedUserId) ||
                        (m.SenderId == selectedUserId && m.ReceiverId == currentUserId))
            .OrderBy(m => m.Timestamp)
            .ToListAsync();

        lock (_messageLock)
        {
            chatMessages = dbMessages.Select(m => new LocalMessage
            {
                Text = m.Text,
                IsOwnMessage = m.SenderId == currentUserId,
                User = m.SenderId == currentUserId ? "Eu" : (m.Sender?.UserName ?? "Cititor"),
                Timestamp = m.Timestamp,
                IsRead = m.IsRead
            }).ToList();
        }
        
        await InvokeAsync(StateHasChanged);
        await ScrollToBottom();
    }

    private async Task Send()
    {
        if (hubConnection is not null && selectedUserId.HasValue && !string.IsNullOrWhiteSpace(messageInput) && currentUserId.HasValue)
        {
            await ProcessAndSendMessage(messageInput);
            messageInput = "";
        }
    }

    private async Task ProcessAndSendMessage(string textContent)
    {
        try
        {
            var now = DateTime.UtcNow; 

            using (var context = DbFactory.CreateDbContext())
            {
                var newDbMessage = new ChatMessage
                {
                    SenderId = currentUserId!.Value,
                    ReceiverId = selectedUserId!.Value,
                    Text = textContent,
                    Timestamp = now,
                    IsRead = false
                };
                context.ChatMessage.Add(newDbMessage);
                await context.SaveChangesAsync();
            }

            await hubConnection!.InvokeAsync("SendPrivateMessage",
                selectedUserId.Value.ToString(),
                textContent,
                currentUserId.Value.ToString(),
                currentUserName);

            lock (_messageLock)
            {
                chatMessages.Add(new LocalMessage
                {
                    User = "Eu",
                    Text = textContent,
                    IsOwnMessage = true,
                    Timestamp = now,
                    IsRead = false
                });
            }

            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Eroare trimitere sau salvare: {ex.Message}");
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("eval", "document.getElementById('chatWindow').scrollTop = document.getElementById('chatWindow').scrollHeight;");
        }
        catch {}
    }

    private void OpenBookModal() => isBookModalOpen = true;
    private void CloseBookModal()
    {
        isBookModalOpen = false;
        selectedBookId = 0;
        bookCommentInput = string.Empty;
    }

    private async Task SendBookRecommendation()
    {
        var book = availableBooks.FirstOrDefault(b => b.Id == selectedBookId);
        if (book != null && !string.IsNullOrWhiteSpace(bookCommentInput))
        {
            string specialMessage = $"[BOOK_CLUB]{book.Title}|{book.Author}|{bookCommentInput}";
            await ProcessAndSendMessage(specialMessage);
            CloseBookModal();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!hasAutoSent && !string.IsNullOrEmpty(targetUserId) && int.TryParse(targetUserId, out int targetId))
            {
                hasAutoSent = true;

                await UpdateSelectedUser(targetId);

                if (!string.IsNullOrWhiteSpace(initialMessage))
                {
                    for (int i = 0; i < 10 && (hubConnection == null || hubConnection.State != HubConnectionState.Connected); i++)
                    {
                        await Task.Delay(200);
                    }

                    if (hubConnection?.State == HubConnectionState.Connected && currentUserId.HasValue)
                    {
                        await ProcessAndSendMessage(initialMessage);
                        Navigation.NavigateTo("/chat", replace: true);
                    }
                    else
                    {
                        hasAutoSent = false;
                    }
                }
            }
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsButtonDisabled) await Send();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) await hubConnection.DisposeAsync();
    }

    public class LocalMessage
    {
        public string User { get; set; } = "";
        public string Text { get; set; } = "";
        public bool IsOwnMessage { get; set; }
        public DateTime Timestamp { get; set; } 
        public bool IsRead { get; set; } 
    }

    public class BookDummy
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
    }
}