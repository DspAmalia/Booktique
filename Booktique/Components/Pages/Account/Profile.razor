@page "/profile"
@using Booktique.Models.MainModels
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Booktique.Components.Pages.Account.Charts

@inject BooktiqueContext DbContext
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor

@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>My Profile | Booktique</PageTitle>

<div class="profile-page-wrapper py-4 py-md-5">
    <div class="container">
        @if (user == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-warning" role="status"></div>
                <p class="mt-2 text-brown fw-medium">Loading your bookish world...</p>
            </div>
        }
        else
        {
            <div class="row g-4 justify-content-center">
                @* Coloana din Stânga: Profil și Info *@
                <div class="col-lg-4 col-md-5">
                    <div class="profile-card shadow border-0 d-flex flex-column p-3 h-100">
                        <div class="avatar-section">
                            <div class="avatar-wrapper shadow-sm">
                                <img src="@(string.IsNullOrEmpty(user.ProfilePicture) ? defaultAvatar : user.ProfilePicture)"
                                     alt="Profile Picture" class="profile-avatar-img" />
                                <button class="change-avatar-btn" @onclick="ToggleAvatarPicker" aria-label="Change avatar">
                                    <i class="bi bi-camera-fill"></i>
                                </button>
                            </div>
                            <h3 class="mt-3 fw-bold text-brown mb-1 fs-4 text-truncate px-2">@user.UserName</h3>
                            <span class="badge rounded-pill bg-light text-brown border px-3 py-2 small">@user.Role</span>
                        </div>

                        <div class="info-section mt-4 px-2">
                            <div class="info-item border-bottom pb-2 d-flex justify-content-between align-items-center">
                                <span class="text-muted small"><i class="bi bi-envelope me-2"></i>Email</span>
                                <span class="fw-medium text-truncate text-end ms-2" style="max-width: 100%;" title="@user.UserEmail">@user.UserEmail</span>
                            </div>
                        </div>

                        <div class="actions-section mt-4 d-grid gap-2 px-2">
                            <button class="btn btn-warning shadow-sm fw-bold py-2 btn-edit text-dark" @onclick="EditProfile">
                                <i class="bi bi-pencil-square me-2"></i>Edit Information
                            </button>
                            <div class="row g-2">
                                <div class="col-6">
                                    <button class="btn btn-outline-secondary w-100 py-2 btn-action" @onclick="Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-danger w-100 py-2 btn-action" @onclick="Delete">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="badges-section mt-5 px-2 text-center">
                            <h6 class="fw-bold text-brown mb-3 small text-uppercase letter-spacing-1">Achievements</h6>
                            <div class="d-flex flex-wrap gap-3 justify-content-center">
                                @foreach (var badge in Badges)
                                {
                                    bool isUnlocked = booksCount >= badge.RequiredBooks;
                                    int missing = badge.RequiredBooks - booksCount;

                                    string tooltip = isUnlocked
                                    ? $"{badge.Name}: {badge.Description}"
                                    : $"Locked: Read {missing} more books to unlock {badge.Name}";

                                    <div class="badge-item @(isUnlocked ? "unlocked" : "locked")" title="@tooltip">
                                        <div class="badge-icon">@badge.Icon</div>
                                        <div class="badge-name">@badge.Name</div>

                                        @if (!isUnlocked)
                                        {
                                            <div class="lock-overlay">
                                                <i class="bi bi-lock-fill"></i>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* Coloana din Dreapta: Statistici și Raft *@
                <div class="col-lg-8 col-md-7">
                    <div class="stats-card shadow border-0 p-4 h-100 d-flex flex-column justify-content-between">
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <h2 class="mb-0 fw-bold text-brown fs-3">Reading Journey</h2>
                                    <p class="text-muted mb-0 small mt-1">
                                        Status:
                                        <span class="badge bg-warning text-dark px-2 py-1 ms-1 fw-bold">
                                            @(booksCount > 10 ? "Avid Reader" : "Bookworm")
                                        </span>
                                    </p>
                                </div>
                                <div class="text-end text-badge-icon">
                                    <span class="fs-1">🏆</span>
                                </div>
                            </div>

                            @* Grid Statistici Rapide la 4 coloane responsive *@
                            <div class="row g-3 mb-4 text-center">
                                <div class="col-6 col-sm-3">
                                    <div class="stats-box p-3 border rounded bg-light h-100 d-flex flex-column justify-content-center">
                                        <h4 class="fw-bold text-brown mb-0 fs-3">@booksCount</h4>
                                        <small class="text-muted fw-medium mt-1">Books</small>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <div class="stats-box p-3 border rounded bg-light h-100 d-flex flex-column justify-content-center">
                                        <h4 class="fw-bold text-brown mb-0 fs-3">@reviewsCount</h4>
                                        <small class="text-muted fw-medium mt-1">Reviews</small>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <div class="stats-box p-3 border rounded bg-light h-100 d-flex flex-column justify-content-center">
                                        <h4 class="fw-bold text-success mb-0 fs-3">🌟 @loyaltyPoints</h4>
                                        <small class="text-muted fw-medium mt-1">Loyalty Points</small>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <div class="stats-box p-3 border rounded bg-light h-100 d-flex flex-column align-items-center justify-content-center h-100">
                                        @if (CurrentRank != null)
                                        {
                                            <div class="d-flex align-items-center justify-content-center gap-1 w-100">
                                                <span class="fs-5 line-height-1">@CurrentRank.Icon</span>
                                                <h4 class="fw-bold mb-0 style-rank-text text-truncate @(booksCount >= 50 ? "text-warning text-shadow-glow" : "text-brown")">
                                                    @CurrentRank?.Name
                                                </h4>
                                            </div>
                                        }
                                        else
                                        {
                                            <h4 class="fw-bold text-muted mb-0 style-rank-text">Novice</h4>
                                        }
                                        <small class="text-muted fw-medium mt-1">Current Rank</small>
                                    </div>
                                </div>
                            </div>

                            @* Logică Progres *@
                            @{
                                int readingGoal = 20;
                                int percentage = (booksCount * 100) / readingGoal;
                                int displayPercentage = Math.Min(percentage, 100);
                                int currentMonth = DateTime.Now.Month;
                                int expectedBooksSoFar = (readingGoal / 12) * currentMonth;
                                int diff = booksCount - expectedBooksSoFar;
                            }

                            <div class="challenge-container p-3 rounded-3 bg-white border mb-4 shadow-sm">
                                <div class="d-flex justify-content-between mb-2 small">
                                    <span class="fw-bold text-brown">@DateTime.Now.Year Reading Challenge</span>
                                    <span class="text-brown fw-bold">@booksCount / @readingGoal books</span>
                                </div>
                                <div class="progress" style="height: 12px; background-color: #f1f3f5; border-radius: 10px;">
                                    <div class="progress-bar bg-warning"
                                         role="progressbar"
                                         style="width: @(displayPercentage)% ; transition: width 1s ease-in-out; border-radius: 10px;"
                                         aria-valuenow="@displayPercentage"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                    </div>
                                </div>

                                <small class="mt-2 d-block text-muted fw-medium text-center text-sm-start">
                                    @if (booksCount >= readingGoal)
                                    {
                                        <span class="text-success fw-bold">🏆 Goal Achieved! You're a legend!</span>
                                    }
                                    else if (diff > 0)
                                    {
                                        <span>You're @diff books ahead of schedule! Keep it up! 🔥</span>
                                    }
                                    else if (diff < 0)
                                    {
                                        <span>You're @Math.Abs(diff) books behind. Time to read! 📖</span>
                                    }
                                    else
                                    {
                                        <span>You're right on track! 🚀</span>
                                    }
                                </small>
                            </div>
                        </div>

                        <div class="mt-2">
                            <h5 class="fw-bold mb-3 text-brown fs-6"><i class="bi bi-bookshelf me-2 text-warning"></i>Your Virtual Bookshelf</h5>
                            <div class="shelf-wrapper position-relative px-1">
                                <div class="book-shelf d-flex gap-3 pb-2">
                                    @if (userBooks != null && userBooks.Any())
                                    {
                                        @foreach (var book in userBooks)
                                        {
                                            <div class="shelf-book shadow-sm"
                                                 @onclick="@(() => NavigationManager.NavigateTo($"/books/details?bookid={book.BookId}"))"
                                                 title="@book.BookTitle by @book.BookAuthor">
                                                <img src="@book.BookCoverPath" alt="@book.BookTitle" loading="lazy" />
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center w-100 py-4 custom-dashed-border">
                                            <p class="text-muted mb-0 small fw-medium">Your shelf is empty. Time for a new adventure! 📚</p>
                                        </div>
                                    }
                                </div>
                                @if (userBooks != null && userBooks.Any())
                                {
                                    <div class="shelf-wood shadow-sm"></div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Modal Alegere Avatar *@
            @if (showAvatarPicker)
            {
                <div class="avatar-modal-overlay" @onclick="ToggleAvatarPicker">
                    <div class="avatar-modal-content card shadow-lg p-4" @onclick:stopPropagation="true">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="mb-0 fw-bold text-brown">Choose your Avatar</h4>
                            <button class="btn-close" @onclick="ToggleAvatarPicker" aria-label="Close modal"></button>
                        </div>
                        <div class="avatar-grid custom-scrollbar">
                            @foreach (var avatarUrl in availableAvatars)
                            {
                                <div class="avatar-option @(user.ProfilePicture == avatarUrl ? "selected" : "")"
                                     @onclick="() => SelectAvatar(avatarUrl)">
                                    <img src="@avatarUrl" alt="Avatar option" />
                                    @if (user.ProfilePicture == avatarUrl)
                                    {
                                        <div class="check-mark"><i class="bi bi-check-lg"></i></div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    :root {
        --brown-primary: #5a3e2b;
        --brown-hover: #4a3324;
        --cream-bg: #fdf6ee;
    }

    body {
        background-image: linear-gradient(rgba(253, 246, 238, 0.90), rgba(253, 246, 238, 0.90)), url('https://i.pinimg.com/1200x/33/99/ac/3399ac1d819b89bdb962b893c9554a41.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        min-height: 100vh;
    }

    .text-brown {
        color: var(--brown-primary);
    }

    .profile-card, .stats-card {
        background: white;
        border-radius: 16px;
        transition: transform 0.2s ease;
    }

    .avatar-section {
        padding: 1rem 0 0.5rem;
        text-align: center;
    }

    .avatar-wrapper {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto;
        border-radius: 50%;
        border: 4px solid white;
        background: #fff;
    }

    .profile-avatar-img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .change-avatar-btn {
        position: absolute;
        bottom: 2px;
        right: 2px;
        background: var(--brown-primary);
        color: white;
        border: 2px solid white;
        border-radius: 50%;
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

        .change-avatar-btn:hover {
            background: var(--brown-hover);
            transform: scale(1.05);
        }

    .btn-edit:hover {
        background-color: #ffca28 !important;
    }

    .btn-action {
        border-width: 2px;
        font-weight: 600;
    }

    .stats-box {
        background-color: #fafbfc !important;
        border: 1px solid #eef0f2 !important;
        border-radius: 12px !important;
        transition: transform 0.2s ease;
    }

        .stats-box:hover {
            transform: translateY(-2px);
        }

    .avatar-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2100;
        padding: 1rem;
    }

    .avatar-modal-content {
        max-width: 420px;
        width: 100%;
        border-radius: 16px;
        border: none;
    }

    .avatar-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        max-height: 320px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .avatar-option {
        cursor: pointer;
        border-radius: 12px;
        padding: 4px;
        border: 3px solid #f1f3f5;
        transition: all 0.2s ease;
        position: relative;
    }

        .avatar-option:hover {
            border-color: #ffe082;
            transform: scale(1.02);
        }

        .avatar-option.selected {
            border-color: var(--brown-primary);
            background-color: #fdf6ee;
        }

        .avatar-option img {
            width: 100%;
            border-radius: 8px;
            aspect-ratio: 1;
            object-fit: cover;
        }

    .check-mark {
        position: absolute;
        top: -6px;
        right: -6px;
        background: var(--brown-primary);
        color: white;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        border: 2px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.15);
    }

    .book-shelf {
        align-items: flex-end;
        height: 160px;
        overflow-x: auto;
        scrollbar-width: thin;
        scroll-behavior: smooth;
    }

    .shelf-book {
        width: 95px;
        height: 135px;
        flex-shrink: 0;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        border-radius: 4px;
        overflow: hidden;
    }

        .shelf-book img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .shelf-book:hover {
            transform: translateY(-8px) scale(1.04);
            z-index: 5;
        }

    .shelf-wood {
        height: 12px;
        background: linear-gradient(to bottom, #d2a679, #86592d);
        border-radius: 6px;
        margin-top: -4px;
        width: 100%;
    }

    .custom-dashed-border {
        border: 2px dashed #d2a679 !important;
        border-radius: 12px;
        background-color: #fffdfb;
    }

    .badge-item {
        position: relative;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #f8f9fa;
        border: 2px solid #eef0f2;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: help;
    }

        .badge-item.unlocked {
            background: white;
            border-color: #ffc107;
            box-shadow: 0 3px 8px rgba(255, 193, 7, 0.15);
        }

            .badge-item.unlocked:hover {
                transform: scale(1.15) rotate(4deg);
                box-shadow: 0 6px 14px rgba(255, 193, 7, 0.25);
                z-index: 10;
            }

        .badge-item.locked {
            filter: grayscale(1);
            opacity: 0.45;
            border-style: dashed;
        }

    .badge-icon {
        font-size: 1.25rem;
        line-height: 1;
    }

    .badge-name {
        font-size: 0.5rem;
        font-weight: 800;
        color: var(--brown-primary);
        text-transform: uppercase;
        margin-top: 2px;
        max-width: 90%;
        text-truncate: true;
    }

    .lock-overlay {
        position: absolute;
        bottom: -2px;
        right: -2px;
        background: var(--brown-primary);
        color: white;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        font-size: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid white;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .style-rank-text {
        font-size: 0.8rem;
    }

    .text-shadow-glow {
        text-shadow: 0 0 8px rgba(255, 193, 7, 0.3);
    }

    .line-height-1 {
        line-height: 1;
    }

    .custom-scrollbar::-webkit-scrollbar,
    .book-shelf::-webkit-scrollbar {
        height: 5px;
        width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb,
    .book-shelf::-webkit-scrollbar-thumb {
        background-color: #dec2a6;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-track,
    .book-shelf::-webkit-scrollbar-track {
        background: transparent;
    }

    @@media (min-width: 576px) {
        .style-rank-text {
            font-size: 0.9rem;
        }

        .badge-item {
            width: 64px;
            height: 64px;
        }

        .badge-icon {
            font-size: 1.4rem;
        }

        .badge-name {
            font-size: 0.55rem;
        }
    }

    @@media (max-width: 767px) {
        .text-badge-icon {
            display: none;
        }
    }
</style>

@code {
    private User? user;
    private bool showAvatarPicker = false;
    private List<Book> userBooks = new();
    private int booksCount = 0;
    private int reviewsCount = 0;
    private int loyaltyPoints = 0;

    private string defaultAvatar = "https://cdn-icons-png.flaticon.com/512/1903/1903172.png";

    private List<string> availableAvatars = new()
    {
        "https://cdn-icons-png.flaticon.com/512/2702/2702134.png",
        "https://cdn-icons-png.flaticon.com/512/2702/2702069.png",
        "https://cdn-icons-png.flaticon.com/512/3532/3532840.png",
        "https://cdn-icons-png.flaticon.com/512/201/201623.png",
        "https://cdn-icons-png.flaticon.com/512/1903/1903162.png",
        "https://cdn-icons-png.flaticon.com/512/1903/1903177.png",
        "https://cdn-icons-png.flaticon.com/512/167/167756.png",
        "https://cdn-icons-png.flaticon.com/512/1903/1903172.png",
        "https://cdn-icons-png.flaticon.com/512/2232/2232688.png"
    };

    private BadgeModel? CurrentRank => Badges
        .Where(b => booksCount >= b.RequiredBooks)
        .OrderByDescending(b => b.RequiredBooks)
        .FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        var username = HttpContextAccessor.HttpContext?.User?.Identity?.Name;

        if (string.IsNullOrWhiteSpace(username))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        user = await DbContext.User.FirstOrDefaultAsync(u => u.UserName == username);

        if (user == null)
        {
            NavigationManager.NavigateTo("/notfound");
            return;
        }

        loyaltyPoints = user.LoyaltyPoints;

        userBooks = await DbContext.Order
            .Where(o => o.UserId == user.UserId)
            .SelectMany(o => o.OrderItems)
            .Select(oi => oi.Book)
            .Distinct()
            .Take(10)
            .ToListAsync();

        booksCount = await DbContext.Order
            .Where(o => o.UserId == user.UserId)
            .SelectMany(o => o.OrderItems)
            .CountAsync();

        reviewsCount = await DbContext.Review
            .Where(r => r.UserId == user.UserId)
            .CountAsync();
    }

    private void ToggleAvatarPicker() => showAvatarPicker = !showAvatarPicker;

    private async Task SelectAvatar(string url)
    {
        if (user != null)
        {
            user.ProfilePicture = url;
            DbContext.User.Update(user);
            await DbContext.SaveChangesAsync();
            showAvatarPicker = false;
        }
    }

    private void EditProfile() => NavigationManager.NavigateTo($"/users/edit?userid={user?.UserId}");
    private void Logout() => NavigationManager.NavigateTo("/logout");
    private void Delete() => NavigationManager.NavigateTo("/delete");

    private class BadgeModel
    {
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "";
        public int RequiredBooks { get; set; }
        public string Description { get; set; } = "";
    }

    private List<BadgeModel> Badges = new()
    {
        new BadgeModel { Name = "Newbie", Icon = "🌱", RequiredBooks = 1, Description = "Your first journey begins!" },
        new BadgeModel { Name = "Reader", Icon = "📖", RequiredBooks = 5, Description = "5 books collected!" },
        new BadgeModel { Name = "Bibliophile", Icon = "📚", RequiredBooks = 10, Description = "Double digits! 10 books." },
        new BadgeModel { Name = "Book Wyrm", Icon = "🐉", RequiredBooks = 20, Description = "Hoarding 20+ treasures!" },
        new BadgeModel { Name = "Legend", Icon = "👑", RequiredBooks = 50, Description = "A true Master of Stories." }
    };
}