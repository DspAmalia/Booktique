@page "/admin/reports/users/{Role?}/{Sub?}/{Search?}"
@using Microsoft.EntityFrameworkCore
@using Booktique.Models.MainModels
@inject IDbContextFactory<BooktiqueContext> DbFactory
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Manager")]
@rendermode InteractiveServer

<div class="container py-4 no-print text-end">
    <a href="/admin/dashboard/users" class="btn btn-sm btn-outline-secondary me-2">BACK</a>
    <button class="btn btn-warning px-4 fw-bold shadow-sm rounded-pill" onclick="window.print()">
        <i class="bi bi-printer me-2"></i> PRINT CLIENT LIST
    </button>
</div>

<div class="invoice-container p-5 bg-white mx-auto border shadow-sm">
    @* HEADER SECTION *@
    <div class="row mb-5 border-bottom-gold pb-4">
        <div class="col-7 d-flex align-items-center">
            <img src="/images/logo.png" alt="Booktique Logo" style="height: 80px; width: auto;" class="me-3" />
            <div>
                <h1 class="text-blue fw-bold mb-0" style="font-size: 2.5rem;">BOOKTIQUE</h1>
                <p class="text-muted small mt-2 uppercase tracking-1">CRM & User Management</p>
            </div>
        </div>

        <div class="col-5 text-end">
            <h2 class="invoice-title">CLIENTS REPORT</h2>
            <div class="invoice-meta mt-3 small">
                <p class="mb-0"><strong>FILTERS:</strong> @(Role == "All" ? "All Roles" : Role) | @(Sub == "All" ? "All Plans" : Sub)</p>
                @if (!string.IsNullOrEmpty(Search))
                {
                    <p class="mb-0"><strong>SEARCH:</strong> "@Search"</p>
                }
                <p class="mb-0"><strong>GEN. DATE:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>

    @* DATA TABLE *@
    <table class="table table-hover mt-4">
        <thead class="bg-invoice-blue text-white">
            <tr>
                <th class="p-3 border-0">CLIENT ID</th>
                <th class="p-3 border-0">IDENTITY</th>
                <th class="p-3 border-0">EMAIL</th>
                <th class="p-3 border-0 text-center">ROLE</th>
                <th class="p-3 border-0 text-center">SUBSCRIPTION</th>
                <th class="p-3 border-0 text-end">LOYALTY PTS</th>
            </tr>
        </thead>
        <tbody class="small">
            @if (clientsList == null || !clientsList.Any())
            {
                <tr><td colspan="6" class="text-center py-4">No clients found for the selected criteria.</td></tr>
            }
            else
            {
                @foreach (var user in clientsList)
                {
                    <tr>
                        <td class="p-3 fw-bold">#@user.UserId</td>
                        <td class="p-3 fw-bold text-blue">@user.UserName</td>
                        <td class="p-3 text-muted">@user.UserEmail</td>
                        <td class="p-3 text-center">
                            <span class="status-text text-dark">@user.Role</span>
                        </td>
                        <td class="p-3 text-center">
                            <span class="status-text">@(user.IsSubscribed == User.SubscriptionLevel.None ? "Standard" : user.IsSubscribed)</span>
                        </td>
                        <td class="p-3 text-end fw-bold">@user.LoyaltyPoints</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @* SIGNATURE & SUMMARY *@
    <div class="row mt-5 pt-5">
        <div class="col-6">
            <p class="mb-1 small text-muted">Authorized Manager Signature</p>
            <div class="border-bottom border-dark my-4" style="height:40px; width: 250px;"></div>
        </div>
        <div class="col-6 text-end">
            <p class="mt-4 small text-muted">Total Clients in Report: <strong>@clientsList?.Count</strong></p>
            <p class="small text-muted">Total Premium Users: <strong>@clientsList?.Count(u => u.IsSubscribed != User.SubscriptionLevel.None)</strong></p>
        </div>
    </div>
</div>

<style>
    :root {
        --report-blue: #2c3e50;
        --invoice-gold: #c5a059;
    }

    .invoice-container {
        max-width: 1000px;
        min-height: 297mm;
        background: white;
    }

    .invoice-title {
        color: var(--invoice-gold);
        letter-spacing: 2px;
        font-weight: 700;
    }

    .bg-invoice-blue {
        background-color: var(--report-blue) !important;
    }

    .border-bottom-gold {
        border-bottom: 3px solid var(--invoice-gold) !important;
    }

    .border-bottom-blue {
        border-bottom: 3px solid var(--report-blue) !important;
    }

    .text-blue {
        color: var(--report-blue);
    }

    .status-text {
        text-transform: uppercase;
        font-weight: 600;
        font-size: 0.75rem;
    }

    .uppercase {
        text-transform: uppercase;
    }

    .tracking-1 {
        letter-spacing: 1px;
    }

    .btn-warning {
        color: white;
        border-radius: 50px;
        transition: all 0.3s;
    }

        .btn-warning:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .btn-outline-secondary {
        border-radius: 50px;
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        .invoice-container, .invoice-container * {
            visibility: visible;
        }

        .invoice-container {
            position: absolute;
            left: 0;
            top: 0;
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            box-shadow: none !important;
        }

        .no-print {
            display: none !important;
        }

        .bg-invoice-blue {
            -webkit-print-color-adjust: exact !important;
            background-color: #2c3e50 !important;
            color: white !important;
        }
    }
</style>

@code {
    [Parameter] public string? Role { get; set; }
    [Parameter] public string? Sub { get; set; }
    [Parameter] public string? Search { get; set; }

    private List<User> clientsList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var query = context.User.AsQueryable();

        if (!string.IsNullOrEmpty(Role) && Role != "All")
            query = query.Where(u => u.Role == Role);

        if (!string.IsNullOrEmpty(Sub) && Sub != "All" && Enum.TryParse<User.SubscriptionLevel>(Sub, out var subLevel))
            query = query.Where(u => u.IsSubscribed == subLevel);

        if (!string.IsNullOrEmpty(Search))
            query = query.Where(u => u.UserName.Contains(Search) || u.UserEmail.Contains(Search));

        clientsList = await query.OrderBy(u => u.UserName).ToListAsync();
    }
}