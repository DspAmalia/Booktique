@page "/admin/orders"
@using Booktique.Models.MainModels
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BooktiqueContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Order Management | Booktique</PageTitle>

<div class="container-fluid py-4 min-vh-100">
    <div class="mb-4 px-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="fw-bold text-dark m-0">Order Management</h2>
            </div>
            <div class="text-end">
                <div class="text-muted fw-semibold">Total Orders: @CurrentTotalCount</div>
            </div>
        </div>

        <div class="d-flex justify-content-start">
            <div class="search-box position-relative">
                <i class="bi bi-search position-absolute top-50 start-3 translate-middle-y text-muted small ps-1"></i>
                <input type="text" class="form-control rounded-pill shadow-sm ps-4"
                       placeholder="Search by Order ID or City..." @bind="searchTerm" @bind:event="oninput" />
            </div>
        </div>
    </div>

    @if (allOrders == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 custom-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-table">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Order Date</th>
                            <th>Customer</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Change Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in FilteredOrders)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-brown">#@order.OrderId</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="small fw-bold">User #@order.UserId</div>
                                    <div class="text-muted small"><i class="bi bi-geo-alt-fill me-1"></i>@order.City</div>
                                </td>
                                <td class="fw-bold text-brown">@order.TotalAmount.ToString("N2") RON</td>
                                <td>
                                    <span class="badge rounded-pill @GetStatusClass(order.Status)">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <select class="form-select form-select-sm border shadow-sm rounded-pill"
                                            style="width: 140px;"
                                            @onchange="(e) => UpdateStatus(order, e)">
                                        @foreach (var status in Enum.GetValues<OrderStatus>())
                                        {
                                            <option value="@status" selected="@(status == order.Status)">@status</option>
                                        }
                                    </select>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-warning btn-sm rounded-pill px-3 shadow-sm text-white fw-bold action-btn" @onclick="() => ShowDetails(order)">
                                        <i class="bi bi-eye-fill me-1"></i>View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* --- MODERN MODAL --- *@
@if (showModal && selectedOrder != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-white border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold text-dark">Order Summary #@selectedOrder.OrderId</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body px-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 border">
                                <h6 class="text-uppercase text-muted small fw-bold"><i class="bi bi-truck me-1"></i>Shipping Info</h6>
                                <p class="mb-1 text-dark">@selectedOrder.ShippingAddress</p>
                                <p class="mb-1 fw-bold text-brown">@selectedOrder.City</p>
                                <p class="mb-0 text-muted small">Tel: @selectedOrder.PhoneNumber</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 border h-100">
                                <h6 class="text-uppercase text-muted small fw-bold"><i class="bi bi-credit-card me-1"></i>Payment & Date</h6>
                                <p class="mb-1 text-dark">Method: <span class="badge bg-secondary rounded-pill">@selectedOrder.PaymentMethod</span></p>
                                <p class="mb-0 text-muted small">Date: @selectedOrder.OrderDate.ToString("f")</p>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3 text-dark">Purchased Items</h6>
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle">
                            <thead class="text-muted small border-bottom">
                                <tr>
                                    <th>Item Name</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in selectedOrder.OrderItems)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@(item.Book?.BookTitle ?? "Digital Product")</td>
                                        <td class="text-center fw-semibold">@item.Quantity</td>
                                        <td class="text-end text-muted">@item.UnitPrice.ToString("N2") RON</td>
                                        <td class="text-end fw-bold text-brown">@((item.Quantity * item.UnitPrice).ToString("N2")) RON</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 py-3 px-4 rounded-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted me-1">Total Amount:</span>
                        <span class="h4 fw-bold text-brown mb-0">@selectedOrder.TotalAmount.ToString("N2") RON</span>
                    </div>
                    <button type="button" class="btn btn-secondary rounded-pill px-4" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    body {
        background-color: #fdf6ee !important;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif !important;
    }

    :root {
        --brown-primary: #5a3e2b;
        --cream-bg: #fdf6ee;
    }

    .text-brown {
        color: var(--brown-primary);
    }

    .search-box {
        width: 320px;
    }

        .search-box input {
            font-size: 0.9rem;
            border: 1px solid rgba(90, 62, 43, 0.15);
        }

            .search-box input:focus {
                border-color: var(--brown-primary);
                box-shadow: 0 0 0 0.25rem rgba(90, 62, 43, 0.1);
            }

    .custom-card {
        border: 1px solid rgba(90, 62, 43, 0.08) !important;
        border-radius: 16px;
        overflow: hidden;
    }

    .custom-table thead th {
        background-color: #fcf9f5 !important;
        color: #7a6e65 !important;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.8px;
        padding: 16px 20px !important;
        border-bottom: 2px solid rgba(90, 62, 43, 0.1) !important;
    }

    .custom-table tbody tr {
        transition: background-color 0.2s ease-in-out;
    }

        .custom-table tbody tr:hover {
            background-color: #fbf3e9 !important;
        }

    .custom-table tbody td {
        padding: 14px 20px !important;
        border-bottom: 1px solid rgba(90, 62, 43, 0.05) !important;
        font-size: 0.9rem;
    }

    .badge {
        font-weight: 600;
        padding: 0.5em 0.8em;
    }

    .btn-warning {
        background-color: var(--brown-primary);
        border-color: var(--brown-primary);
    }

        .btn-warning:hover {
            background-color: #473122;
            border-color: #473122;
            transform: translateY(-1px);
        }

    .modal-content {
        border-radius: 16px;
    }
</style>

@code {
    private List<Order>? allOrders;
    private Order? selectedOrder;
    private bool showModal = false;
    private string searchTerm = "";

    // Proprietate calculată care filtrează lista în timp real local
    private IEnumerable<Order> FilteredOrders
    {
        get
        {
            if (allOrders == null) return Enumerable.Empty<Order>();

            if (string.IsNullOrWhiteSpace(searchTerm)) return allOrders;

            // Elimină eventualul caracter `#` adăugat de manager la căutarea unui ID
            var cleanTerm = searchTerm.Replace("#", "").Trim();

            return allOrders.Where(o =>
                o.OrderId.ToString().Contains(cleanTerm) ||
                (o.City != null && o.City.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            );
        }
    }

    // Returnează dinamic numărul total bazat doar pe rezultatele filtrate
    private int CurrentTotalCount => FilteredOrders.Count();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        using var context = DbFactory.CreateDbContext();
        allOrders = await context.Order
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    private async Task ShowDetails(Order order)
    {
        using var context = DbFactory.CreateDbContext();
        selectedOrder = await context.Order
            .Include(o => o.OrderItems)
                .ThenInclude(oi => oi.Book)
            .FirstOrDefaultAsync(o => o.OrderId == order.OrderId);

        if (selectedOrder != null) showModal = true;
    }

    private void CloseModal() { showModal = false; selectedOrder = null; }

    private string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-warning-subtle text-warning-emphasis border border-warning",
        OrderStatus.Confirmed => "bg-info-subtle text-info-emphasis border border-info",
        OrderStatus.Shipped => "bg-primary-subtle text-primary-emphasis border border-primary",
        OrderStatus.Delivered => "bg-success-subtle text-success-emphasis border border-success",
        OrderStatus.Cancelled => "bg-danger-subtle text-danger-emphasis border border-danger",
        _ => "bg-secondary-subtle text-secondary-emphasis"
    };

    private async Task UpdateStatus(Order order, ChangeEventArgs e)
    {
        if (Enum.TryParse<OrderStatus>(e.Value?.ToString(), out var newStatus))
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var dbOrder = await context.Order.FindAsync(order.OrderId);

            if (dbOrder != null)
            {
                dbOrder.Status = newStatus;
                dbOrder.LastUpdated = DateTime.Now;

                // 1. Creăm obiectul fără proprietatea TargetUrl pentru moment
                var notification = new Notification
                    {
                        UserId = dbOrder.UserId,
                        OrderId = dbOrder.OrderId,
                        Message = $"Your order status #{dbOrder.OrderId} was updated to: {newStatus}.",
                        CreatedAt = DateTime.Now,
                        IsRead = false
                        // Am scos TargetUrl de aici pentru a evita eroarea de compilare
                    };

                // 2. Adăugăm notificarea în context și salvăm o dată
                // În acest moment, baza de date generează ID-ul unic pentru cheia primară (ex: 3029)
                context.Notification.Add(notification);
                await context.SaveChangesAsync();

                // 3. Acum că notification.Id este complet populat și valid, construim URL-ul dorit
                notification.TargetUrl = $"/order-details/{notification.OrderId}?notifId={notification.NotificationId}";

                // 4. Salvăm din nou pentru a actualiza coloana TargetUrl în baza de date
                await context.SaveChangesAsync();

                // 5. Actualizăm interfața grafică Blazor
                order.Status = newStatus;
                StateHasChanged();
            }
        }
    }
}