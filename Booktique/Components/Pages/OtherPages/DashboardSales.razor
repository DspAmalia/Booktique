@page "/admin/dashboard/sales"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Booktique.Models.MainModels
@using ClosedXML.Excel
@inject BooktiqueContext DbContext
@inject IJSRuntime JS
@inject IDbContextFactory<BooktiqueContext> DbFactory
@attribute [Authorize(Roles = "Manager")]
@inject NavigationManager NavManager
@rendermode InteractiveServer

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-brown fw-bold">Sales <span class="text-success">Report</span></h2>
        <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 p-3 bg-white rounded-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="small fw-bold text-muted">START DATE</label>
                <input type="date" class="form-control" @bind="startDate" />
            </div>
            <div class="col-md-2">
                <label class="small fw-bold text-muted">END DATE</label>
                <input type="date" class="form-control" @bind="endDate" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-success w-100 rounded-pill" @onclick="ApplyFilters">
                    <i class="bi bi-filter"></i> Filter
                </button>
            </div>
            <div class="col-md-3">
                <button class="btn btn-success w-100 rounded-pill" @onclick="ExportToExcel" disabled="@(filteredSales == null || !filteredSales.Any())">
                    <i class="bi bi-file-earmark-excel"></i> Export Excel
                </button>
            </div>
            <div class="col-md-3 text-end">
                <button class="btn btn-dark rounded-pill px-4 shadow-sm w-100" @onclick="GoToPrintReport">
                    <i class="bi bi-printer me-2"></i> Report
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="p-3 bg-light rounded-3 border-start border-success border-4">
                <div class="small text-muted text-uppercase">Total Sales in Period</div>
                <div class="h3 fw-bold">@(filteredSales?.Count ?? 0)</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 bg-light rounded-3 border-start border-primary border-4">
                <div class="small text-muted text-uppercase">Total Revenue</div>
                <div class="h3 fw-bold text-success">@totalRevenue.ToString("N2") RON</div>
            </div>
        </div>
    </div>

    <div id="reportTable" class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Order ID</th>
                        <th>Date</th>
                        <th>Customer ID</th>
                        <th>Method</th>
                        <th class="text-end pe-4">Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filteredSales == null)
                    {
                        <tr><td colspan="5" class="text-center py-5">Loading data...</td></tr>
                    }
                    else if (!filteredSales.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted">No records found for this period.</td></tr>
                    }
                    else
                    {
                        @foreach (var order in filteredSales)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@order.OrderId</td>
                                <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td>User #@order.UserId</td>
                                <td><span class="badge bg-secondary">@order.PaymentMethod</span></td>
                                <td class="text-end pe-4 fw-bold">@order.TotalAmount.ToString("N2") RON</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private DateTime startDate = DateTime.Now.AddMonths(-1);
    private DateTime endDate = DateTime.Now;
    private List<Order>? filteredSales;
    private decimal totalRevenue;

    protected override async Task OnInitializedAsync()
    {
        await ApplyFilters();
    }

    private async Task ApplyFilters()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        var start = startDate.Date;
        var end = endDate.Date.AddDays(1).AddTicks(-1);

        filteredSales = await context.Order
            .Where(o => o.OrderDate >= start && o.OrderDate <= end)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();

        totalRevenue = filteredSales.Sum(o => o.TotalAmount);

        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        if (filteredSales == null || !filteredSales.Any()) return;

        using (var workbook = new XLWorkbook())
        {
            var worksheet = workbook.Worksheets.Add("Sales Report");

            // Antetul adaptat pentru structura raportului de vânzări
            string[] headers = { "Order ID", "Date", "Customer ID", "Payment Method", "Total Amount (RON)" };
            for (int i = 0; i < headers.Length; i++)
                worksheet.Cell(1, i + 1).Value = headers[i];

            var headerRow = worksheet.Row(1);
            headerRow.Style.Font.Bold = true;
            headerRow.Style.Fill.BackgroundColor = XLColor.FromHtml("#F1E6D8");

            int rowIdx = 2;
            foreach (var order in filteredSales)
            {
                worksheet.Cell(rowIdx, 1).Value = $"#{order.OrderId}";
                worksheet.Cell(rowIdx, 2).Value = order.OrderDate.ToString("dd.MM.yyyy HH:mm");
                worksheet.Cell(rowIdx, 3).Value = $"User #{order.UserId}";
                worksheet.Cell(rowIdx, 4).Value = order.PaymentMethod?.ToString() ?? "N/A";
                worksheet.Cell(rowIdx, 5).Value = order.TotalAmount;

                // Formatare celulă ca număr zecimal monetar
                worksheet.Cell(rowIdx, 5).Style.NumberFormat.Format = "#,##0.00";
                rowIdx++;
            }

            worksheet.Columns().AdjustToContents();

            using (var stream = new MemoryStream())
            {
                workbook.SaveAs(stream);
                var fileBytes = stream.ToArray();
                var base64String = Convert.ToBase64String(fileBytes);
                var fileName = $"Booktique_Sales_{DateTime.Now:yyyyMMdd}.xlsx";

                // Injectare inline script executat ca Blob pentru stabilitate maximă
                var jsInlineCode = $@"
                    (function() {{
                        const byteCharacters = atob('{base64String}');
                        const byteNumbers = new Array(byteCharacters.length);
                        for (let i = 0; i < byteCharacters.length; i++) {{
                            byteNumbers[i] = byteCharacters.charCodeAt(i);
                        }}
                        const byteArray = new Uint8Array(byteNumbers);
                        const blob = new Blob([byteArray], {{ type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' }});

                        const url = URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = url;
                        link.download = '{fileName}';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        URL.revokeObjectURL(url);
                    }})();
                ";

                await JS.InvokeVoidAsync("eval", jsInlineCode);
            }
        }
    }

    private void GoToPrintReport()
    {
        var start = startDate.ToString("yyyy-MM-dd");
        var end = endDate.ToString("yyyy-MM-dd");
        NavManager.NavigateTo($"/admin/reports/sales/{start}/{end}");
    }
}