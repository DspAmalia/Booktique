@page "/admin/dashboard/sales"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Booktique.Models.MainModels
@inject BooktiqueContext DbContext
@inject IJSRuntime JS
@inject IDbContextFactory<BooktiqueContext> DbFactory
@attribute [Authorize(Roles = "Manager")]
@inject NavigationManager NavManager
@rendermode InteractiveServer

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-brown fw-bold">Sales <span class="text-success">Report</span></h2>
        <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 p-3 bg-white rounded-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="small fw-bold text-muted">START DATE</label>
                <input type="date" class="form-control" @bind="startDate" />
            </div>
            <div class="col-md-3">
                <label class="small fw-bold text-muted">END DATE</label>
                <input type="date" class="form-control" @bind="endDate" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-success w-100 rounded-pill" @onclick="ApplyFilters">
                    <i class="bi bi-filter"></i> Filter
                </button>
            </div>
            <div class="col-md-4 text-end">
                <button class="btn btn-dark rounded-pill px-4 shadow-sm" @onclick="GoToPrintReport">
                    <i class="bi bi-printer me-2"></i> Report
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="p-3 bg-light rounded-3 border-start border-success border-4">
                <div class="small text-muted text-uppercase">Total Sales in Period</div>
                <div class="h3 fw-bold">@(filteredSales?.Count ?? 0)</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 bg-light rounded-3 border-start border-primary border-4">
                <div class="small text-muted text-uppercase">Total Revenue</div>
                <div class="h3 fw-bold text-success">@totalRevenue.ToString("N2") RON</div>
            </div>
        </div>
    </div>

    <div id="reportTable" class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Order ID</th>
                        <th>Date</th>
                        <th>Customer ID</th>
                        <th>Method</th>
                        <th class="text-end pe-4">Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filteredSales == null)
                    {
                        <tr><td colspan="5" class="text-center py-5">Loading data...</td></tr>
                    }
                    else if (!filteredSales.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted">No records found for this period.</td></tr>
                    }
                    else
                    {
                        @foreach (var order in filteredSales)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@order.OrderId</td>
                                <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td>User #@order.UserId</td>
                                <td><span class="badge bg-secondary">@order.PaymentMethod</span></td>
                                <td class="text-end pe-4 fw-bold">@order.TotalAmount.ToString("N2") RON</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private DateTime startDate = DateTime.Now.AddMonths(-1);
    private DateTime endDate = DateTime.Now;
    private List<Order>? filteredSales;
    private decimal totalRevenue;

    protected override async Task OnInitializedAsync()
    {
        await ApplyFilters();
    }

    private async Task ApplyFilters()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        // Luăm începutul zilei pentru StartDate și sfârșitul zilei pentru EndDate
        var start = startDate.Date;
        var end = endDate.Date.AddDays(1).AddTicks(-1);

        filteredSales = await context.Order
            .Where(o => o.OrderDate >= start && o.OrderDate <= end)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();

        totalRevenue = filteredSales.Sum(o => o.TotalAmount);

        // Forțăm UI-ul să se randeze cu noile date
        StateHasChanged();
    }

    private void GoToPrintReport()
    {
        // Trimitem datele sub formă de string (yyyy-MM-dd) în URL
        var start = startDate.ToString("yyyy-MM-dd");
        var end = endDate.ToString("yyyy-MM-dd");
        NavManager.NavigateTo($"/admin/reports/sales/{start}/{end}");
    }
}