@page "/order-details/{OrderId:int}"
@using Booktique.Models.MainModels
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BooktiqueContext> DbFactory
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container mt-5 mb-5">
    @* --- HEADER SECTION --- *@
    <div class="hero-wrapper p-4 mb-4 hero-card-shadow d-flex justify-content-between align-items-center">
        <div>
            <span class="badge rounded-pill bg-accent-soft text-brown mb-2 px-3 py-2">
                <i class="bi bi-receipt me-2"></i>Order Summary
            </span>
            <h2 class="fw-bold text-brown-dark mb-0">Order #@OrderId</h2>
            <p class="text-muted-brown small mb-0">Placed on: @order?.OrderDate.ToString("dd MMM yyyy, HH:mm")</p>
        </div>
        <a class="btn btn-search-go rounded-pill px-4" href="/">
            <i class="bi bi-arrow-left me-2"></i>Back Home
        </a>
    </div>

    @if (order == null)
    {
        <div class="text-center p-5 glass-card">
            <div class="spinner-border text-accent-yellow" role="status"></div>
            <p class="mt-3 text-muted-brown">Searching the library archives...</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @* --- LEFT SIDE: LOGISTICS --- *@
            <div class="col-lg-4">
                @* Status Card *@
                <div class="filters-sidebar p-4 mb-4 shadow-sm">
                    <label class="filter-label"><i class="bi bi-info-circle me-2"></i>Delivery Status</label>
                    <div class="mt-2 mb-4 text-center">
                        <span class="badge rounded-pill @GetStatusClass(order.Status) px-4 py-3 fs-6 w-100 shadow-sm">
                            @order.Status.ToString()
                        </span>
                    </div>

                    <label class="filter-label"><i class="bi bi-geo-alt me-2"></i>Shipping Address</label>
                    <p class="text-brown-dark fw-bold mb-1">@order.ShippingAddress</p>
                    <p class="text-muted small mb-4">@order.City • @order.PhoneNumber</p>

                    <label class="filter-label"><i class="bi bi-credit-card me-2"></i>Payment</label>
                    <p class="text-brown-dark mb-0">Method: <strong>@order.PaymentMethod</strong></p>
                </div>

                @* Total Card *@
                <div class="top-sales-wrapper p-4 text-center border-0">
                    <h5 class="text-brown-dark fw-bold mb-1">Total Amount</h5>
                    <div class="display-6 text-accent-yellow fw-bold">@order.TotalAmount.ToString("N2") <small>LEI</small></div>
                </div>
            </div>

            @* --- RIGHT SIDE: PRODUCTS --- *@
            <div class="col-lg-8">
                <div class="books-grid-details p-4 bg-white shadow-sm rounded-4">
                    <h5 class="fw-bold text-brown-dark mb-4 px-2">Ordered Masterpieces</h5>

                    <div class="table-responsive">
                        <table class="table align-middle custom-details-table">
                            <thead>
                                <tr class="text-muted-brown small text-uppercase">
                                    <th class="border-0 px-3 pb-3">Book Selection</th>
                                    <th class="border-0 text-center pb-3">Qty</th>
                                    <th class="border-0 text-end px-3 pb-3">Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in order.OrderItems)
                                {
                                    <tr>
                                        <td class="px-3 py-3 border-0">
                                            <div class="d-flex align-items-center">
                                                <div class="item-img-mini me-3 shadow-sm">
                                                    <img src="@item.Book?.BookCoverPath" alt="Cover" />
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-brown-dark">@item.Book?.BookTitle</div>
                                                    <div class="text-muted small">@item.Book?.BookAuthor</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold border-0 text-brown-dark">@item.Quantity</td>
                                        <td class="text-end px-3 fw-bold border-0 text-accent-yellow">@item.UnitPrice.ToString("N2") lei</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    :root {
        --brown-dark: #5a3e2b;
        --brown-muted: #7d6352;
        --accent: #f0a500;
        --accent-soft: rgba(240, 165, 0, 0.15);
        --bg-soft: #fdf6ee;
        --hero-container-bg: #eaddcf;
        --hero-container-accent: #decbb7;
    }

    body {
        background-color: var(--bg-soft);
        font-family: 'Inter', sans-serif;
    }

    /* Unitatate cu Hero din Home */
    .hero-wrapper {
        background: linear-gradient(135deg, var(--hero-container-bg) 0%, var(--hero-container-accent) 100%);
        border-radius: 25px;
        border: 1px solid rgba(90, 62, 43, 0.12);
    }

    .hero-card-shadow {
        box-shadow: 0 15px 35px rgba(90, 62, 43, 0.1);
    }

    .text-brown-dark {
        color: var(--brown-dark);
    }

    .text-muted-brown {
        color: var(--brown-muted);
    }

    .text-accent-yellow {
        color: var(--accent);
    }

    .bg-accent-soft {
        background-color: var(--accent-soft);
    }

    /* Stil Sidebar / Info Cards */
    .filters-sidebar {
        background: white;
        border-radius: 24px;
        border: 1px solid rgba(90, 62, 43, 0.08);
    }

    .filter-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #8b7355;
        font-weight: 800;
        margin-bottom: 10px;
        display: block;
    }

    /* Buton stilizat ca în Home */
    .btn-search-go {
        background: var(--brown-dark);
        color: white;
        border: none;
        transition: all 0.3s;
    }

        .btn-search-go:hover {
            background: var(--accent);
            color: white;
            transform: translateY(-2px);
        }

    /* Tabel & Produse */
    .custom-details-table tbody tr {
        background: #fdfaf8;
        border-radius: 12px;
        margin-bottom: 10px;
        display: table-row; /* Reset pentru table layout */
    }

    .item-img-mini {
        width: 45px;
        height: 65px;
        background: white;
        border-radius: 6px;
        overflow: hidden;
    }

        .item-img-mini img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Status Badges */
    .status-pending {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .status-confirmed {
        background: #cce5ff;
        color: #004085;
        border: 1px solid #b8daff;
    }

    .status-shipped {
        background: #e2fbe8;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .status-delivered {
        background: #d1e7dd;
        color: #0f5132;
        border: 1px solid #badbcc;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #842029;
        border: 1px solid #f5c2c7;
    }

    /* Reutilizare din top-sales-wrapper pentru total */
    .top-sales-wrapper {
        background: #fff;
        border-radius: 24px;
        border: 2px solid var(--accent) !important;
        box-shadow: 0 10px 25px rgba(240, 165, 0, 0.1) !important;
    }
</style>

@code {
    [Parameter] public int OrderId { get; set; }
    private Order? order;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderDetails();
        await CheckAndMarkAsRead();
    }

    private async Task CheckAndMarkAsRead()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("notifId", out var notifIdStr))
        {
            if (int.TryParse(notifIdStr, out int notifId))
            {
                await using var ctx = await DbFactory.CreateDbContextAsync();
                await ctx.Notification
                    .Where(n => n.NotificationId == notifId && !n.IsRead)
                    .ExecuteUpdateAsync(s => s.SetProperty(n => n.IsRead, true));
            }
        }
    }

    private async Task LoadOrderDetails()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        order = await ctx.Order
            .Include(o => o.OrderItems)
                .ThenInclude(oi => oi.Book)
            .FirstOrDefaultAsync(o => o.OrderId == OrderId);
    }

    private string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "status-pending",
        OrderStatus.Confirmed => "status-confirmed",
        OrderStatus.Shipped => "status-shipped",
        OrderStatus.Delivered => "status-delivered",
        OrderStatus.Cancelled => "status-cancelled",
        _ => "bg-secondary text-white"
    };
}