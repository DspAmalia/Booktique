@page "/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using Booktique.Models.MainModels
@using static Booktique.Models.MainModels.User
@implements IAsyncDisposable
@inject IDbContextFactory<BooktiqueContext> DbFactory
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Manager")]

<PageTitle>User Management | Booktique</PageTitle>

<div class="container py-4">
    <div class="mb-4 px-3">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h2 class="fw-bold text-dark m-0">User Management</h2>
            </div>
            <div class="text-end">
                <div class="d-flex gap-2 justify-content-end mb-2">
                    <a href="users/create" class="btn btn-warning rounded-pill px-3 btn-sm shadow-sm fw-bold">
                        <i class="bi bi-person-plus-fill me-1"></i>Create New
                    </a>
                    <a href="/admin/dashboard" class="btn btn-outline-secondary rounded-pill px-3 btn-sm shadow-sm fw-bold">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </a>
                </div>
                <div class="text-muted small">Total Users: @CurrentTotalCount</div>
            </div>
        </div>

        <div class="d-flex justify-content-start">
            <div class="search-box position-relative">
                <i class="bi bi-search position-absolute top-50 start-3 translate-middle-y text-muted small ps-1"></i>
                <input type="text" class="form-control rounded-pill shadow-sm ps-4"
                       placeholder="Search by username..." @bind="searchTerm" @bind:event="oninput" />
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden custom-card">
        <div class="card-body p-0">
            @if (allUsers == null)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-brown" role="status"></div>
                </div>
            }
            else
            {
                <QuickGrid Class="table align-middle mb-0 custom-grid" Items="FilteredUsersAsQueryable">

                    <TemplateColumn Title="Profile" Class="col-profile text-center">
                        <div class="avatar-wrapper d-inline-block">
                            <img src="@(string.IsNullOrEmpty(context.ProfilePicture) ? "https://www.shutterstock.com/image-illustration/man-open-book-illustration-element-260nw-1103282219.jpg" : context.ProfilePicture)"
                                 class="rounded-circle border border-2 border-white shadow-sm"
                                 style="width: 40px; height: 40px; object-fit: cover;" />
                        </div>
                    </TemplateColumn>

                    <PropertyColumn Title="Username" Property="user => user.UserName" Sortable="true" Class="fw-bold text-brown" />

                    <PropertyColumn Title="Email" Property="user => user.UserEmail" Sortable="true" Class="text-muted" />

                    <TemplateColumn Title="Role" Sortable="true">
                        @{
                            string roleClass, icon;
                            switch (context.Role)
                            {
                                case "Administrator":
                                    roleClass = "bg-warning-subtle text-warning-dark border-warning-subtle";
                                    icon = "bi-shield-fill-check";
                                    break;
                                case "Manager":
                                    roleClass = "bg-danger-subtle text-danger border-danger-subtle";
                                    icon = "bi-shield-lock-fill";
                                    break;
                                default:
                                    roleClass = "bg-light text-secondary border-secondary-subtle";
                                    icon = "bi-person-fill";
                                    break;
                            }
                        }
                        <span class="badge @roleClass border rounded-pill px-3 py-2 fw-semibold d-inline-flex align-items-center">
                            <i class="bi @icon me-1.5"></i> @context.Role
                        </span>
                    </TemplateColumn>

                    <TemplateColumn Title="Subscription Plan" Sortable="true">
                        @switch (context.IsSubscribed)
                        {
                            case SubscriptionLevel.Yearly:
                                <span class="badge rounded-pill bg-warning-subtle text-warning-dark border border-warning-subtle px-3 py-2 fw-semibold d-inline-flex align-items-center">
                                    <i class="bi bi-star-fill me-1.5 text-warning"></i> Yearly Premium
                                </span>
                                break;

                            case SubscriptionLevel.Monthly:
                                <span class="badge rounded-pill bg-info-subtle text-info-dark border border-info-subtle px-3 py-2 fw-semibold d-inline-flex align-items-center">
                                    <i class="bi bi-calendar-check-fill me-1.5 text-info"></i> Monthly
                                </span>
                                break;

                            case SubscriptionLevel.None:
                            default:
                                <span class="badge rounded-pill bg-light text-muted border px-3 py-2 fw-normal d-inline-flex align-items-center">
                                    <i class="bi bi-x-circle me-1.5 text-secondary"></i> No Active Plan
                                </span>
                                break;
                        }
                    </TemplateColumn>

                    <TemplateColumn Title="Actions" Align="Align.End" Class="pe-4">
                        <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                            <a href="@($"users/details?userid={context.UserId}")" class="btn btn-sm btn-white action-btn" title="Details">
                                <i class="bi bi-eye-fill text-primary"></i>
                            </a>
                            <a href="@($"users/delete?userid={context.UserId}")" class="btn btn-sm btn-white action-btn border-start" title="Delete">
                                <i class="bi bi-trash-fill text-danger"></i>
                            </a>
                        </div>
                    </TemplateColumn>
                </QuickGrid>
            }
        </div>
    </div>
</div>

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        background-color: #fdf6ee;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    :root {
        --brown-primary: #5a3e2b;
        --cream-bg: #fdf6ee;
        --warning-dark: #856404;
        --info-dark: #0c5460;
    }

    body {
        background-color: var(--cream-bg);
    }

    .search-box {
        width: 320px;
    }

        .search-box input {
            font-size: 0.9rem;
            border: 1px solid rgba(90, 62, 43, 0.15);
        }

            .search-box input:focus {
                border-color: var(--brown-primary);
                box-shadow: 0 0 0 0.25rem rgba(90, 62, 43, 0.1);
            }

    .text-brown {
        color: var(--brown-primary);
    }

        .text-brown.spinner-border {
            color: var(--brown-primary) !important;
        }

    .btn-warning {
        color: white;
        background-color: var(--brown-primary);
        border-color: var(--brown-primary);
    }

        .btn-warning:hover {
            background-color: #473122;
            border-color: #473122;
            color: white;
        }

    .text-warning-dark {
        color: var(--warning-dark);
    }

    .text-info-dark {
        color: var(--info-dark);
    }

    .me-1\.5 {
        margin-right: 0.375rem !important;
    }

    .custom-card {
        border: 1px solid rgba(90, 62, 43, 0.08) !important;
    }

    .custom-grid {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    ::deep .table thead th {
        background-color: #fcf9f5 !important;
        color: #7a6e65 !important;
        font-size: 0.75rem !important;
        font-weight: 700 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.8px !important;
        padding: 16px 20px !important;
        border-bottom: 2px solid rgba(90, 62, 43, 0.1) !important;
    }

    ::deep .table tbody tr {
        transition: all 0.2s ease-in-out;
    }

        ::deep .table tbody tr:hover {
            background-color: #fbf3e9 !important;
            transform: scale(1.002);
        }

    ::deep .table tbody td {
        padding: 14px 20px !important;
        border-bottom: 1px solid rgba(90, 62, 43, 0.05) !important;
        font-size: 0.9rem;
    }

    .col-profile {
        width: 90px;
    }

    .avatar-wrapper img {
        transition: transform 0.2s;
    }

    ::deep .table tbody tr:hover .avatar-wrapper img {
        transform: scale(1.1);
    }

    .btn-white {
        background-color: #ffffff;
        border: none;
    }

    .action-btn {
        padding: 6px 12px;
        transition: background-color 0.2s;
    }

        .action-btn:hover {
            background-color: #f8f9fa;
        }

    ::deep .quickgrid {
        display: table;
        width: 100%;
    }
</style>

@code {
    private BooktiqueContext context = default!;
    private List<User>? allUsers;
    private string searchTerm = "";

    // Proprietatea filtrează local lista descărcată inițial
    private IEnumerable<User>? FilteredUsers =>
        string.IsNullOrWhiteSpace(searchTerm)
        ? allUsers
        : allUsers?.Where(u => u.UserName != null && u.UserName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    // Convertește rezultatul în IQueryable pentru a fi compatibil cu QuickGrid
    private IQueryable<User>? FilteredUsersAsQueryable => FilteredUsers?.AsQueryable();

    // Această proprietate calculează dinamic numărul total bazat pe lista deja filtrată
    private int CurrentTotalCount => FilteredUsers?.Count() ?? 0;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();

        // Încarcă toți utilizatorii din baza de date
        allUsers = await context.User.ToListAsync();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}