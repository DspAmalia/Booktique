    @* pentru harta *@
    <script>
        function initMap() {
            var mapContainer = document.getElementById('map');

            if (mapContainer) {
                console.log("initMap called - container found");
                var map = L.map('map').setView([44.4325, 26.1039], 16);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap contributors'
                }).addTo(map);
                L.marker([44.4325, 26.1039])
                    .addTo(map)
                    .bindPopup("<div style='text-align:center'><b>Booktique </b><br>Strada Lipscani nr. 12, București</div>");

            } else {
                console.log("initMap skipped - container not found on this page");
            }
        }
        document.addEventListener("DOMContentLoaded", initMap);
    </script>

    @* pentru stergere cache *@
    <script>
        window.clearBrowserCacheAndStorage = function () {
            // 1. Golește stocările text
            localStorage.clear();
            sessionStorage.clear();

            // 2. Forțează ștergerea cookie-urilor accesibile din JS prin setarea unei date din trecut
            document.cookie.split(";").forEach(function (c) {
                document.cookie = c.replace(/^ +/, "").replace(/=.*/, "=;expires=" + new Date().toUTCString() + ";path=/");
            });

            // 3. Curăță cache-ul de aplicație (dacă există)
            if ('caches' in window) {
                caches.keys().then(function (names) {
                    for (let name of names) caches.delete(name);
                });
            }
        };
    </script>

    @* pentru export in excel *@
    <script>
        window.downloadFileFromBytes = (fileName, byteBase64) => {
            const link = document.createElement('a');
            link.download = fileName;
            link.href = "data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64," + byteBase64;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
    </script>

    <script>
        window.desktopNotifications = {
            requestPermission: async function () {
                if (!("Notification" in window)) {
                    console.log("Acest browser nu suportă notificări pe desktop.");
                    return false;
                }

                if (Notification.permission === "granted") {
                    return true;
                }

                if (Notification.permission !== "denied") {
                    const permission = await Notification.requestPermission();
                    return permission === "granted";
                }

                return false;
            },

            showNotification: function (title, options) {
                if ("Notification" in window && Notification.permission === "granted") {
                    new Notification(title, options);
                }
            }
        };
    </script>
