@inherits LayoutComponentBase
@using Booktique.Components.Pages
@using Booktique.Models.MainModels
@using Booktique.Models.Services
@using Microsoft.EntityFrameworkCore
@using static Booktique.Models.MainModels.User
@inject CartService cartService
@implements IDisposable
@inject AuthenticationStateProvider AuthProvider
@inject IDbContextFactory<BooktiqueContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ChatNotificationService NotificationService

<div class="page">
    <main>
        <!-- TOPBAR -->
        <header class="top-row px-3 shadow-sm d-flex align-items-center justify-content-between">

            <!-- Zona Stânga: Brand & Navigație Principală -->
            <div class="d-flex align-items-center flex-grow-1 overflow-hidden me-2">
                <a class="navbar-brand me-3" href="">
                    <strong>Booktique</strong>
                </a>

                <nav class="nav-scrollable d-flex align-items-center gap-1">
                    <NavLink class="nav-horizontal-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door"></i> Home
                    </NavLink>
                    <NavLink class="nav-horizontal-link" href="/favorites">
                        <i class="bi bi-heart"></i> Favorites
                    </NavLink>

                    @if (isSubscribed)
                    {
                        <NavLink class="nav-horizontal-link position-relative d-inline-flex align-items-center" href="/chat">
                            <i class="bi bi-chat-dots me-1"></i> Messenger
                            @if (NotificationService.TotalUnreadCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm badge-messenger">
                                    @NotificationService.TotalUnreadCount
                                </span>
                            }
                        </NavLink>
                    }
                    @if (currentSubscriptionLevel == 2)
                    {
                        <NavLink class="nav-horizontal-link" href="/antique">
                            <i class="bi bi-bank"></i> Antique Booktique
                        </NavLink>
                    }
                </nav>
            </div>

            <!-- Zona Dreapta: Panouri Administrative, Notificări, Utilizator -->
            <div class="d-flex align-items-center gap-1 flex-shrink-0">

                <AuthorizeView Roles="Admin, Administrator, Manager">
                    <a class="nav-horizontal-link admin-theme p-2" href="/admin/dashboard" title="Admin Dashboard">
                        <i class="bi bi-speedometer2"></i>
                    </a>
                </AuthorizeView>

                <AuthorizeView Roles="User, Manager, Admin, Administrator">
                    <Authorized>
                        <div class="dropdown">
                            <a class="nav-horizontal-link position-relative dropdown-trigger-btn p-2"
                               type="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                <i class="bi bi-bell"></i>
                                @if (unreadCount > 0)
                                {
                                    <span class="cart-badge bg-danger">
                                        @unreadCount
                                    </span>
                                }
                            </a>
                            <!-- Meniul dropdown de notificări -->
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-modern notification-dropdown shadow-lg border-0 p-0">
                                <li class="dropdown-header-modern">
                                    <span class="fw-bold text-brown-dark">Notifications</span>
                                    @if (unreadCount > 0)
                                    {
                                        <span class="badge bg-accent-soft text-accent rounded-pill fs-7">@unreadCount new</span>
                                    }
                                </li>
                                <div class="dropdown-scroll-area">
                                    @if (userNotifications == null || !userNotifications.Any())
                                    {
                                    <li class="text-center py-4 px-3 text-muted-brown fs-7">
                                        <i class="bi bi-bell-slash d-block fs-3 mb-2 opacity-50"></i>
                                        You don't have new notifications.
                                    </li>
                                    }
                                    else
                                    {
                                        @foreach (var n in userNotifications)
                                        {
                                        <li>
                                            <a class="dropdown-item notification-item @(n.IsRead ? "is-read" : "is-unread")"
                                               href="@(
                                                    string.IsNullOrEmpty(n.TargetUrl)
                                                        ? $"/order-details/{n.OrderId}?notifId={n.NotificationId}"
                                                        : (n.TargetUrl.Contains("notifId=")
                                                            ? n.TargetUrl
                                                            : (n.TargetUrl.Contains("?") ? $"{n.TargetUrl}&notifId={n.NotificationId}" : $"{n.TargetUrl}?notifId={n.NotificationId}"))
                                                )">
                                                <div class="d-flex gap-2 align-items-start w-100">
                                                        @if (!n.IsRead)
                                                        {
                                                        <span class="notification-dot mt-1.5"></span>
                                                        }
                                                    <div class="flex-grow-1">
                                                        <div class="notification-msg mb-1">
                                                                @* iconiță diferită în funcție de tipul notificării (Comandă sau Carte) *@
                                                                @if (n.OrderId != null)
                                                                {
                                                                <i class="bi bi-box-seam text-primary me-1"></i>
                                                                }
                                                                else
                                                                {
                                                                <i class="bi bi-heart-fill text-danger me-1"></i>
                                                                }
                                                                @n.Message
                                                        </div>
                                                        <div class="notification-time">@n.CreatedAt.ToString("g")</div>
                                                    </div>
                                                </div>
                                            </a>
                                        </li>
                                        }
                                    }
                        </div>
                        <li class="dropdown-footer-modern">
                            <span class="fs-7 text-muted opacity-75">Recent updates</span>
                        </li>
                        </ul>
            </div>
            </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-horizontal-link d-none d-lg-flex" href="/contact">
                        <i class="bi bi-headset"></i> Contact
                    </NavLink>

                    <div class="dropdown">
                        <button class="user-pill dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (!string.IsNullOrEmpty(profilePictureUrl))
                                {
                                <img src="@profilePictureUrl" class="user-avatar-nav" alt="Profile" />
                                }
                                else
                                {
                                <span class="user-initial">@context.User.Identity?.Name?[0].ToString().ToUpper()</span>
                                }
                            <span class="d-none d-sm-inline ms-1 text-brown-dark fw-semibold fs-7">@context.User.Identity?.Name</span>
                            <i class="bi bi-chevron-down ms-1 fs-8 text-muted opacity-70"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-modern user-dropdown shadow-lg border-0 p-2">
                            <li class="user-dropdown-info px-3 py-2 mb-2">
                                <div class="fs-7 text-muted">Connected as</div>
                                <div class="fw-bold text-brown-dark text-truncate">@context.User.Identity?.Name</div>
                            </li>
                            <li>
                                <a class="dropdown-item text-dark" href="/profile">
                                    <i class="bi bi-person me-2 text-muted"></i>Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item text-dark d-flex align-items-center justify-content-between" href="/cart">
                                    <span><i class="bi bi-cart3 me-2 text-muted"></i>Cart</span>
                                        @if (cartService.Items.Any())
                                        {
                                        <span class="badge bg-accent text-white rounded-pill px-2 py-0.5 fs-8">
                                                @cartService.Items.Sum(i => i.Quantity)
                                        </span>
                                        }
                                </a>
                            </li>
                            <AuthorizeView Roles="User, Manager" Context="SubContext">
                                <li>
                                    <a class="dropdown-item text-dark" href="/subscriptions">
                                        <i class="bi bi-star me-2 text-muted"></i>Subscriptions
                                    </a>
                                </li>
                            </AuthorizeView>
                            <li class="my-2 border-top-subtle"></li>
                            <li>
                                <a class="dropdown-item logout-item" href="/logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </a>
                            </li>
                        </ul>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="login-pill">Login</a>
                </NotAuthorized>
            </AuthorizeView>
</div>
</header>

<!-- CONȚINUT PAGINĂ -->
<article class="content px-4">
            @Body

    <!-- Buton plutitor AI -->
    <div class="ai-floating-container">
        <a href="/ask-ai" class="btn btn-ai-chat shadow-lg d-flex align-items-center justify-content-center text-decoration-none">
            <i class="bi bi-magic me-2"></i>
            <span class="fw-bold d-none d-sm-inline">Booktique AI</span>
        </a>
    </div>
</article>
    </main>
</div>

<style>
    :root {
        --brown-dark: #4a3325;
        --brown-muted: #7d6352;
        --accent: #e09600;
        --accent-soft: rgba(240, 165, 0, 0.1);
        --dropdown-bg: #ffffff;
    }

    /* Topbar Core layout */
    .top-row {
        min-height: 4.5rem;
        height: auto;
        background-color: #ceb9a6 !important;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        position: sticky;
        top: 0;
        z-index: 2000 !important;
        padding: 0.5rem 1.5rem;
        flex-wrap: wrap;
        gap: 10px;
    }

    .navbar-brand strong {
        color: #2d3436;
        font-size: 1.4rem;
    }

    .nav-horizontal-link, .user-pill, .login-pill {
        flex-shrink: 0;
    }

    .nav-horizontal-link {
        color: #4a3325;
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .nav-horizontal-link:hover {
            color: #2d1a0f !important;
            background-color: rgba(61, 43, 31, 0.06);
        }

        .nav-horizontal-link.active {
            color: var(--brown-dark) !important;
            background-color: rgba(61, 43, 31, 0.12) !important;
        }

    .admin-theme {
        color: #6c5ce7;
    }

    /* Badges */
    .cart-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        background: #ff4757;
        color: white;
        font-size: 0.65rem;
        padding: 2px 5px;
        border-radius: 50%;
    }

    .badge-messenger {
        font-size: 0.65rem;
        padding: 0.25em 0.45em;
        transform: translate(-10%, -30%) !important;
        z-index: 10;
    }

    /* Dropdowns */
    .dropdown-trigger-btn {
        cursor: pointer;
    }

    .dropdown-menu-modern {
        display: block;
        visibility: hidden;
        opacity: 0;
        transform: translateY(12px) scale(0.98);
        transition: all 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
        pointer-events: none;
        background-color: var(--dropdown-bg);
        border-radius: 16px;
        margin-top: 12px !important;
        overflow: hidden;
    }

        .dropdown-menu-modern.show {
            visibility: visible;
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: auto;
        }

    .notification-dropdown {
        width: 340px;
    }

    .user-dropdown {
        width: 220px;
    }

    .dropdown-header-modern {
        padding: 14px 18px;
        border-bottom: 1px solid rgba(74, 51, 37, 0.06);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.95rem;
    }

    .dropdown-scroll-area {
        max-height: 320px;
        overflow-y: auto;
        scrollbar-width: thin;
    }

    .dropdown-footer-modern {
        padding: 10px 18px;
        border-top: 1px solid rgba(74, 51, 37, 0.06);
        text-align: center;
        background-color: #faf8f5;
        border-bottom-left-radius: 16px;
        border-bottom-right-radius: 16px;
    }

    .dropdown-item {
        padding: 10px 16px;
        margin: 0 8px;
        width: calc(100% - 16px);
        border-radius: 10px;
        transition: all 0.2s ease;
        color: var(--brown-dark);
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
    }

        .dropdown-item:hover {
            background-color: var(--accent-soft);
            color: var(--brown-dark);
            padding-left: 20px;
        }

    /* Notification Items */
    .notification-item {
        border-radius: 0;
        padding: 12px 18px;
        margin: 0;
        width: 100%;
        border-bottom: 1px solid rgba(74, 51, 37, 0.03);
        white-space: normal;
    }

        .notification-item:hover {
            padding-left: 22px;
        }

        .notification-item.is-unread {
            background-color: rgba(240, 165, 0, 0.03);
        }

            .notification-item.is-unread:hover {
                background-color: var(--accent-soft);
            }

    .notification-dot {
        width: 7px;
        height: 7px;
        background-color: var(--accent);
        border-radius: 50%;
        flex-shrink: 0;
    }

    .notification-msg {
        font-size: 0.85rem;
        font-weight: 600;
        color: #2d3436;
        line-height: 1.3;
    }

    .notification-item.is-read .notification-msg {
        font-weight: 400;
        color: #636e72;
    }

    .notification-time {
        font-size: 0.72rem;
        color: #b2bec3;
    }

    /* User Pill */
    .user-pill {
        background: #f8f9fa;
        border: 1px solid rgba(74, 51, 37, 0.1);
        padding: 2px 10px 2px 2px !important;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 6px;
        height: 38px;
        transition: all 0.2s ease;
    }

        .user-pill:hover {
            background: #f1f3f5;
            border-color: rgba(74, 51, 37, 0.2);
        }

    .user-avatar-nav {
        width: 32px !important;
        height: 32px !important;
        border-radius: 50% !important;
        object-fit: cover;
        display: block;
    }

    .user-initial {
        width: 32px;
        height: 32px;
        background: #fdcb6e;
        color: #000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .login-pill {
        background: #2d3436;
        color: white !important;
        padding: 8px 20px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
    }

    .user-dropdown-info {
        border-bottom: 1px solid rgba(74, 51, 37, 0.06);
    }

    .border-bottom-subtle, .border-top-subtle {
        border-color: rgba(74, 51, 37, 0.06) !important;
    }

    .logout-item {
        color: #dc3545 !important;
    }

        .logout-item:hover {
            background-color: rgba(220, 53, 69, 0.08);
        }

    .dropdown-toggle::after {
        display: none;
    }

    /* Floating AI Button */
    .ai-floating-container {
        position: fixed;
        bottom: 25px;
        right: 25px;
        z-index: 9999;
    }

    .btn-ai-chat {
        background: linear-gradient(135deg, #f0a500 0%, #d48802 100%);
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 50px;
        font-size: 1rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .btn-ai-chat:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(240, 165, 0, 0.4);
            color: white;
        }

    /* Utilities */
    .fs-7 {
        font-size: 0.85rem !important;
    }

    .fs-8 {
        font-size: 0.75rem !important;
    }

    .text-accent {
        color: var(--accent) !important;
    }

    .bg-accent-soft {
        background-color: var(--accent-soft) !important;
    }

    .bg-accent {
        background-color: var(--accent) !important;
    }

    .text-brown-dark {
        color: var(--brown-dark) !important;
    }

    .text-muted-brown {
        color: var(--brown-muted) !important;
    }

    /* Media queries */
    @@media (max-width: 576px) {
        .top-row {
            padding: 0.5rem 0.5rem;
            justify-content: center;
        }

        .nav-horizontal-link {
            padding: 0.5rem 0.5rem;
            font-size: 0.9rem;
        }

        .user-pill {
            padding: 2px 6px 2px 2px !important;
        }
    }
</style>

@code {
    private bool isSubscribed = false;
    private string? profilePictureUrl;
    private List<Notification> userNotifications = new();
    private int unreadCount = 0;
    private int currentSubscriptionLevel = 0;

    private void NavigateTo(string url)
    {
        Nav.NavigateTo(url);
    }

    protected override async Task OnParametersSetAsync()
    {
        await CheckSubscriptionStatus();
        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        ?? user.FindFirst("UserId")?.Value;

        if (int.TryParse(userIdStr, out int userId))
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            userNotifications = await ctx.Notification
                .Where(n => n.UserId == userId)
                .OrderByDescending(n => n.CreatedAt)
                .Take(5)
                .ToListAsync();

            unreadCount = userNotifications.Count(n => !n.IsRead);

            int unreadChatMessages = await ctx.Set<ChatMessage>()
                .Where(m => m.ReceiverId == userId && !m.IsRead)
                .CountAsync();

            NotificationService.UpdateUnreadCount(unreadChatMessages);
        }
    }

    private async Task CheckSubscriptionStatus()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            using var ctx = DbFactory.CreateDbContext();

            var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                            ?? user.FindFirst("UserId")?.Value;

            if (int.TryParse(userIdStr, out int userId))
            {
                var dbUser = await ctx.User.FindAsync(userId);
                if (dbUser != null)
                {
                    isSubscribed = dbUser.IsSubscribed != SubscriptionLevel.None;
                    currentSubscriptionLevel = (int)dbUser.IsSubscribed;
                    profilePictureUrl = dbUser.ProfilePicture;
                }
            }
            else
            {
                var dbUser = await ctx.User.FirstOrDefaultAsync(u => u.UserName == user.Identity.Name);
                if (dbUser != null)
                {
                    isSubscribed = dbUser.IsSubscribed != SubscriptionLevel.None;
                    profilePictureUrl = dbUser.ProfilePicture;
                }
            }
        }
        else
        {
            isSubscribed = false;
            currentSubscriptionLevel = 0;
            profilePictureUrl = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeManager.getTheme");
            await JS.InvokeVoidAsync("themeManager.setTheme", theme);
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        cartService.OnChange += StateHasChanged;
        NotificationService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        cartService.OnChange -= StateHasChanged;
        NotificationService.OnChange -= StateHasChanged;
    }
}